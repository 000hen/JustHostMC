<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="JustHostMC.App.Views.ShopSearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:JustHostMC.App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:JustHostMC.App.Models"
    xmlns:viewModels="using:JustHostMC.App.ViewModels"
    mc:Ignorable="d">

    <Grid x:Name="SearchPageRoot">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="LeftSafeArea" Width="0" />
            <ColumnDefinition x:Name="ContentSafeArea" Width="*" />
            <ColumnDefinition x:Name="RightSafeArea" Width="0" />
        </Grid.ColumnDefinitions>
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="SafeAreaStates">
                <VisualState x:Name="FluidSafeArea">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="LeftSafeArea.Width" Value="0" />
                        <Setter Target="ContentSafeArea.Width" Value="*" />
                        <Setter Target="RightSafeArea.Width" Value="0" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="ConstrainedSafeArea">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1440" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="LeftSafeArea.Width" Value="*" />
                        <Setter Target="ContentSafeArea.Width" Value="1440" />
                        <Setter Target="RightSafeArea.Width" Value="*" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <controls:AdaptiveFilterLayout x:Name="SearchFilterLayout"
                                       Grid.Column="1"
                                       CompactPadding="12,8,12,0"
                                       WidePadding="24,16,24,0"
                                       RowSpacing="12"
                                       HeaderSpacing="12"
                                       CompactColumnSpacing="0"
                                       WideColumnSpacing="20"
                                       WideMinWidth="1050"
                                       WideFilterWidth="292"
                                       CompactFilterMaxHeight="620"
                                       FilterRailIncludesHeader="True"
                                       FilterRailCornerRadius="10">
            <controls:AdaptiveFilterLayout.HeaderContent>
                <StackPanel Spacing="2">
                    <TextBlock x:Uid="ShopSearchResultsHeading"
                               Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="{x:Bind ResultSummary(ViewModel.TotalResults, ViewModel.Query), Mode=OneWay}" />
                </StackPanel>
            </controls:AdaptiveFilterLayout.HeaderContent>

            <controls:AdaptiveFilterLayout.MainContent>
                <Grid>
                    <ListView ItemsSource="{x:Bind ViewModel.SearchResults, Mode=OneWay}"
                              HorizontalContentAlignment="Stretch"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              SelectionMode="None"
                              IsItemClickEnabled="True"
                              ItemClick="OnItemClick"
                              IncrementalLoadingTrigger="Edge">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,8" />
                                <Setter Property="CornerRadius" Value="8" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:ShopProjectItem">
                                <Grid Padding="14" ColumnSpacing="14" MinHeight="106">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="76" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Grid Width="76" Height="76" VerticalAlignment="Top">
                                        <Border Background="{ThemeResource AccentFillColorTertiaryBrush}"
                                                CornerRadius="10">
                                            <TextBlock Text="{x:Bind Initial}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="28"
                                                       FontWeight="SemiBold"
                                                       Visibility="{x:Bind FallbackIconVisibility}" />
                                        </Border>
                                        <Border CornerRadius="10"
                                                Visibility="{x:Bind IconVisibility}">
                                            <Image Source="{x:Bind Icon}" Stretch="UniformToFill" />
                                        </Border>
                                    </Grid>

                                    <StackPanel Grid.Column="1" Spacing="5">
                                        <StackPanel Spacing="1">
                                            <TextBlock Text="{x:Bind Title}"
                                                       Style="{StaticResource SubtitleTextBlockStyle}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{x:Bind AuthorLine}"
                                                       Visibility="{x:Bind AuthorVisibility}"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                        </StackPanel>
                                        <TextBlock Text="{x:Bind Summary}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextWrapping="Wrap"
                                                   MaxLines="2"
                                                   TextTrimming="CharacterEllipsis" />
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Padding="7,2"
                                                    CornerRadius="10"
                                                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                                    Visibility="{x:Bind ProjectTypeVisibility}">
                                                <TextBlock Text="{x:Bind ProjectTypeLabel}"
                                                           Style="{StaticResource CaptionTextBlockStyle}" />
                                            </Border>
                                            <TextBlock Grid.Column="1"
                                                       Text="{x:Bind CategoriesText}"
                                                       VerticalAlignment="Center"
                                                       Visibility="{x:Bind CategoriesVisibility}"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </StackPanel>

                                    <Border Grid.Column="2"
                                            Padding="9,5"
                                            CornerRadius="12"
                                            VerticalAlignment="Top"
                                            Background="{ThemeResource ControlFillColorSecondaryBrush}">
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <FontIcon Glyph="&#xE896;"
                                                      FontSize="11"
                                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Text="{x:Bind DownloadsText}"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <ItemsControl Opacity="0.62"
                                  ItemsSource="{x:Bind SkeletonItems}"
                                  Visibility="{x:Bind ShowSkeleton(ViewModel.IsSearchLoading, ViewModel.SearchResults.Count), Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Height="106"
                                        Margin="0,0,0,8"
                                        Padding="14"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <Grid ColumnSpacing="14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="76" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="76" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="76" Height="76"
                                                Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                                CornerRadius="10" />
                                        <StackPanel Grid.Column="1" Spacing="9" VerticalAlignment="Center">
                                            <Border Width="220" Height="17"
                                                    HorizontalAlignment="Left"
                                                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                                    CornerRadius="4" />
                                            <Border Height="11"
                                                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                                    CornerRadius="3" />
                                            <Border Width="360" MaxWidth="360" Height="11"
                                                    HorizontalAlignment="Left"
                                                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                                    CornerRadius="3" />
                                            <Border Width="130" Height="17"
                                                    HorizontalAlignment="Left"
                                                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                                    CornerRadius="8" />
                                        </StackPanel>
                                        <Border Grid.Column="2"
                                                Width="64" Height="24"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                                CornerRadius="12" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="10"
                                Visibility="{x:Bind ShowEmpty(ViewModel.IsSearchLoading, ViewModel.TotalResults), Mode=OneWay}">
                        <FontIcon Glyph="&#xE721;"
                                  FontSize="32"
                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <TextBlock x:Uid="ShopSearchEmpty"
                                   MaxWidth="420"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Grid>
            </controls:AdaptiveFilterLayout.MainContent>

            <controls:AdaptiveFilterLayout.CompactFilterContent>
                <StackPanel Width="280" Spacing="16">
                    <TextBlock x:Uid="ShopFilterHeading"
                               Style="{StaticResource SubtitleTextBlockStyle}" />
                    <ComboBox x:Name="CompactSortCombo"
                              x:Uid="ShopSortCombo"
                              HorizontalAlignment="Stretch"
                              SelectedIndex="0"
                              SelectionChanged="OnCompactSortChanged">
                        <ComboBoxItem x:Uid="ShopSortRelevance" />
                        <ComboBoxItem x:Uid="ShopSortDownloads" />
                        <ComboBoxItem x:Uid="ShopSortFollows" />
                        <ComboBoxItem x:Uid="ShopSortNewest" />
                        <ComboBoxItem x:Uid="ShopSortUpdated" />
                    </ComboBox>
                    <Rectangle Height="1"
                               Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                    <StackPanel Spacing="4">
                        <TextBlock x:Uid="ShopCompatibilityHeading"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock x:Uid="ShopCompatibilityDescription"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <CheckBox Content="{x:Bind ViewModel.VersionFilterLabel, Mode=OneWay}"
                              IsChecked="{x:Bind ViewModel.UseVersionFilter, Mode=TwoWay}"
                              Visibility="{x:Bind ViewModel.HasVersionFilter}"
                              Click="OnVersionFilterChanged" />
                    <CheckBox Content="{x:Bind ViewModel.LoaderFilterLabel, Mode=OneWay}"
                              IsChecked="{x:Bind ViewModel.UseLoaderFilter, Mode=TwoWay}"
                              Visibility="{x:Bind ViewModel.HasLoaderFilter}"
                              Click="OnLoaderFilterChanged" />
                    <StackPanel Spacing="8"
                                Visibility="{x:Bind BoolToVisibility(ViewModel.HasCategoryFilters), Mode=OneWay}">
                        <Rectangle Height="1"
                                   Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                        <TextBlock x:Uid="ShopCategoriesHeading"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <ItemsControl ItemsSource="{x:Bind ViewModel.CategoryFilters, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:ShopCategoryFilter">
                                    <CheckBox Content="{x:Bind Label}"
                                              IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                              Tag="{x:Bind}"
                                              Click="OnCategoryFilterChanged" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                    <Button x:Uid="ShopResetFilters"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Click="OnResetFilters" />
                </StackPanel>
            </controls:AdaptiveFilterLayout.CompactFilterContent>

            <controls:AdaptiveFilterLayout.WideFilterContent>
                <StackPanel Padding="20" Spacing="18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Uid="ShopFilterHeading"
                                   Style="{StaticResource SubtitleTextBlockStyle}"
                                   VerticalAlignment="Center" />
                        <Button x:Uid="ShopResetFilters"
                                Grid.Column="1"
                                Padding="8,4"
                                Click="OnResetFilters" />
                    </Grid>

                    <ComboBox x:Name="WideSortCombo"
                              x:Uid="ShopSortCombo"
                              HorizontalAlignment="Stretch"
                              SelectedIndex="0"
                              SelectionChanged="OnWideSortChanged">
                        <ComboBoxItem x:Uid="ShopSortRelevance" />
                        <ComboBoxItem x:Uid="ShopSortDownloads" />
                        <ComboBoxItem x:Uid="ShopSortFollows" />
                        <ComboBoxItem x:Uid="ShopSortNewest" />
                        <ComboBoxItem x:Uid="ShopSortUpdated" />
                    </ComboBox>

                    <Rectangle Height="1"
                               Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <StackPanel Spacing="6">
                        <TextBlock x:Uid="ShopSourceHeading"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <Border Padding="10,8"
                                CornerRadius="6"
                                Background="{ThemeResource ControlFillColorSecondaryBrush}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8D4;" FontSize="13" />
                                <TextBlock Text="{x:Bind ViewModel.SelectedShopName, Mode=OneWay}"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>
                        <TextBlock x:Uid="ShopSourceDescription"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Rectangle Height="1"
                               Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <StackPanel Spacing="5">
                        <TextBlock x:Uid="ShopCompatibilityHeading"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock x:Uid="ShopCompatibilityDescription"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <CheckBox Content="{x:Bind ViewModel.VersionFilterLabel, Mode=OneWay}"
                              IsChecked="{x:Bind ViewModel.UseVersionFilter, Mode=TwoWay}"
                              Visibility="{x:Bind ViewModel.HasVersionFilter}"
                              Click="OnVersionFilterChanged" />
                    <CheckBox Content="{x:Bind ViewModel.LoaderFilterLabel, Mode=OneWay}"
                              IsChecked="{x:Bind ViewModel.UseLoaderFilter, Mode=TwoWay}"
                              Visibility="{x:Bind ViewModel.HasLoaderFilter}"
                              Click="OnLoaderFilterChanged" />

                    <StackPanel Spacing="8"
                                Visibility="{x:Bind BoolToVisibility(ViewModel.HasCategoryFilters), Mode=OneWay}">
                        <Rectangle Height="1"
                                   Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                        <StackPanel Spacing="4">
                            <TextBlock x:Uid="ShopCategoriesHeading"
                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock x:Uid="ShopCategoriesDescription"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <ItemsControl ItemsSource="{x:Bind ViewModel.CategoryFilters, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:ShopCategoryFilter">
                                    <CheckBox Content="{x:Bind Label}"
                                              IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                              Tag="{x:Bind}"
                                              Click="OnCategoryFilterChanged" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <InfoBar x:Uid="ShopFilterHint"
                             IsOpen="True"
                             IsClosable="False"
                             Severity="Informational" />
                </StackPanel>
            </controls:AdaptiveFilterLayout.WideFilterContent>
        </controls:AdaptiveFilterLayout>
    </Grid>
</Page>
