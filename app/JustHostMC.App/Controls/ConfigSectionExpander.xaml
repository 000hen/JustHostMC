<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="JustHostMC.App.Controls.ConfigSectionExpander"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:JustHostMC.App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    HorizontalAlignment="Stretch">

    <Expander IsExpanded="{Binding IsExpanded, ElementName=Root, Mode=TwoWay}"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Stretch">
        <Expander.Header>
            <StackPanel Spacing="2">
                <TextBlock Text="{Binding Title, ElementName=Root}"
                           Style="{StaticResource BodyStrongTextBlockStyle}" />
                <TextBlock Text="{Binding Description, ElementName=Root}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="WrapWholeWords" />
            </StackPanel>
        </Expander.Header>

        <StackPanel HorizontalAlignment="Stretch">
            <TextBlock Text="{Binding Message, ElementName=Root}"
                       Margin="8,4"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="WrapWholeWords"
                       Visibility="{Binding HasMessage, ElementName=Root, Converter={StaticResource BoolToVis}}" />

            <ItemsControl ItemsSource="{Binding ItemsSource, ElementName=Root}"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <controls:ConfigEntryEditor Entry="{Binding}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Expander>
</UserControl>
