<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="JustHostMC.App.Views.EngineStdioWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:JustHostMC.App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:JustHostMC.App.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <Grid x:Name="Root" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="MonitorTitleBar">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="ms-appx:///Assets/StoreLogo.png" />
            </TitleBar.IconSource>
        </TitleBar>

        <controls:AdaptiveFilterLayout
            x:Name="MonitorLayout"
            Grid.Row="1"
            Padding="12,8,12,8"
            CompactColumnSpacing="0"
            CompactFilterMaxHeight="560"
            CompactFilterOpening="OnCompactFilterOpening"
            FilterRailCornerRadius="8"
            HeaderSpacing="10"
            RowSpacing="8"
            WideColumnSpacing="10"
            WideFilterWidth="250"
            WideMinWidth="900">
            <controls:AdaptiveFilterLayout.HeaderContent>
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <ToggleButton
                            x:Uid="EngineMonitorStopButton"
                            Checked="OnPauseChanged"
                            Unchecked="OnPauseChanged" />
                        <Button x:Uid="EngineMonitorClearButton" Click="OnClearClick">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                <TextBlock x:Uid="EngineMonitorClearButtonLabel" />
                            </StackPanel>
                        </Button>
                        <Button x:Uid="EngineMonitorCopyButton" Click="OnCopyClick">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="14" Glyph="&#xE8C8;" />
                                <TextBlock x:Uid="EngineMonitorCopyButtonLabel" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                </Grid>
            </controls:AdaptiveFilterLayout.HeaderContent>

            <controls:AdaptiveFilterLayout.MainContent>
                <Border
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <controls:LogViewer
                        Padding="2"
                        Background="Transparent"
                        ItemsSource="{x:Bind VisibleEntries}">
                        <controls:LogViewer.EmptyContent>
                            <TextBlock
                                x:Uid="EngineMonitorEmptyText"
                                Margin="24"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextAlignment="Center" />
                        </controls:LogViewer.EmptyContent>
                        <controls:LogViewer.ItemTemplate>
                            <DataTemplate x:DataType="local:EngineStdioDisplayEntry">
                                <StackPanel Padding="9,5" Spacing="1">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock
                                            FontFamily="Consolas"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Text="{x:Bind LevelLabel}" />
                                        <TextBlock
                                            FontFamily="Consolas"
                                            FontSize="12"
                                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                            Text="|" />
                                        <TextBlock
                                            FontFamily="Consolas"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{x:Bind StreamLabel}" />
                                        <TextBlock
                                            FontFamily="Consolas"
                                            FontSize="12"
                                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                            Text="|" />
                                        <TextBlock
                                            FontFamily="Consolas"
                                            FontSize="12"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{x:Bind TimestampText}" />
                                    </StackPanel>
                                    <TextBlock
                                        FontFamily="Consolas"
                                        FontSize="12"
                                        IsTextSelectionEnabled="True"
                                        Text="{x:Bind Message}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </controls:LogViewer.ItemTemplate>
                    </controls:LogViewer>
                </Border>
            </controls:AdaptiveFilterLayout.MainContent>

            <controls:AdaptiveFilterLayout.CompactFilterContent>
                <StackPanel Width="270" Spacing="12">
                    <TextBlock x:Uid="EngineMonitorFiltersLabel" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBox
                        x:Name="CompactSearchBox"
                        x:Uid="EngineMonitorSearchBox"
                        TextChanged="OnSearchTextChanged" />

                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                    <TextBlock x:Uid="EngineMonitorStreamsHeading" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <StackPanel Spacing="2">
                        <CheckBox
                            x:Name="CompactStdOutCheckBox"
                            Checked="OnFilterChanged"
                            Content="STDOUT"
                            IsChecked="True"
                            Unchecked="OnFilterChanged" />
                        <CheckBox
                            x:Name="CompactStdErrCheckBox"
                            Checked="OnFilterChanged"
                            Content="STDERR"
                            IsChecked="True"
                            Unchecked="OnFilterChanged" />
                        <CheckBox
                            x:Name="CompactStdInCheckBox"
                            Checked="OnFilterChanged"
                            Content="STDIN"
                            IsChecked="True"
                            Unchecked="OnFilterChanged" />
                    </StackPanel>

                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                    <TextBlock x:Uid="EngineMonitorLevelsHeading" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <Grid RowSpacing="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <CheckBox
                            x:Name="CompactDebugCheckBox"
                            Checked="OnFilterChanged"
                            Content="DEBUG"
                            IsChecked="True"
                            Unchecked="OnFilterChanged" />
                        <CheckBox
                            x:Name="CompactInfoCheckBox"
                            Grid.Column="1"
                            Checked="OnFilterChanged"
                            Content="INFO"
                            IsChecked="True"
                            Unchecked="OnFilterChanged" />
                        <CheckBox
                            x:Name="CompactWarningCheckBox"
                            Grid.Row="1"
                            Checked="OnFilterChanged"
                            Content="WARN"
                            IsChecked="True"
                            Unchecked="OnFilterChanged" />
                        <CheckBox
                            x:Name="CompactErrorCheckBox"
                            Grid.Row="1"
                            Grid.Column="1"
                            Checked="OnFilterChanged"
                            Content="ERROR"
                            IsChecked="True"
                            Unchecked="OnFilterChanged" />
                    </Grid>
                    <TextBlock
                        x:Uid="EngineMonitorStdinHint"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </controls:AdaptiveFilterLayout.CompactFilterContent>

            <controls:AdaptiveFilterLayout.WideFilterContent>
                <StackPanel Padding="14" Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="14" Glyph="&#xE71C;" />
                        <TextBlock x:Uid="EngineMonitorFiltersLabel" Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                    <TextBox
                        x:Name="WideSearchBox"
                        x:Uid="EngineMonitorSearchBox"
                        TextChanged="OnSearchTextChanged" />

                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                    <TextBlock x:Uid="EngineMonitorStreamsHeading" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <StackPanel Spacing="2">
                        <CheckBox
                            x:Name="WideStdOutCheckBox"
                            Checked="OnFilterChanged"
                            Content="STDOUT"
                            IsChecked="True"
                            Unchecked="OnFilterChanged" />
                        <CheckBox
                            x:Name="WideStdErrCheckBox"
                            Checked="OnFilterChanged"
                            Content="STDERR"
                            IsChecked="True"
                            Unchecked="OnFilterChanged" />
                        <CheckBox
                            x:Name="WideStdInCheckBox"
                            Checked="OnFilterChanged"
                            Content="STDIN"
                            IsChecked="True"
                            Unchecked="OnFilterChanged" />
                    </StackPanel>

                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                    <TextBlock x:Uid="EngineMonitorLevelsHeading" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <Grid RowSpacing="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <CheckBox
                            x:Name="WideDebugCheckBox"
                            Checked="OnFilterChanged"
                            Content="DEBUG"
                            IsChecked="True"
                            Unchecked="OnFilterChanged" />
                        <CheckBox
                            x:Name="WideInfoCheckBox"
                            Grid.Column="1"
                            Checked="OnFilterChanged"
                            Content="INFO"
                            IsChecked="True"
                            Unchecked="OnFilterChanged" />
                        <CheckBox
                            x:Name="WideWarningCheckBox"
                            Grid.Row="1"
                            Checked="OnFilterChanged"
                            Content="WARN"
                            IsChecked="True"
                            Unchecked="OnFilterChanged" />
                        <CheckBox
                            x:Name="WideErrorCheckBox"
                            Grid.Row="1"
                            Grid.Column="1"
                            Checked="OnFilterChanged"
                            Content="ERROR"
                            IsChecked="True"
                            Unchecked="OnFilterChanged" />
                    </Grid>
                    <TextBlock
                        x:Uid="EngineMonitorStdinHint"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </controls:AdaptiveFilterLayout.WideFilterContent>

            <controls:AdaptiveFilterLayout.FooterContent>
                <TextBlock
                    x:Name="StatusText"
                    Margin="4,0"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}" />
            </controls:AdaptiveFilterLayout.FooterContent>
        </controls:AdaptiveFilterLayout>
    </Grid>
</Window>
