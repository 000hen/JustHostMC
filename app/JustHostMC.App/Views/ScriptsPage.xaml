<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="JustHostMC.App.Views.ScriptsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:JustHostMC.App.Models"
    mc:Ignorable="d">

    <ScrollViewer Padding="24"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20" MaxWidth="980" HorizontalAlignment="Stretch">

            <TextBlock x:Uid="ScriptsPageTitle"
                       Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock x:Uid="ScriptsPageSubtitle"
                       TextWrapping="WrapWholeWords"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

            <ProgressBar IsIndeterminate="True"
                         Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVis}}" />

            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                       TextWrapping="WrapWholeWords"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

            <!-- Providers -->
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Uid="ScriptsProvidersHeader"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Style="{StaticResource SubtitleTextBlockStyle}" />
                <Button x:Uid="ScriptsImportProviderButton"
                        Grid.Column="1"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="OnImportProviderClick">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE896;" FontSize="14" />
                        <TextBlock x:Uid="ScriptsImportProviderButtonLabel" />
                    </StackPanel>
                </Button>
            </Grid>

            <TextBlock x:Uid="ScriptsProvidersEmpty"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Visibility="{x:Bind ViewModel.Providers.Count, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />

            <ItemsControl ItemsSource="{x:Bind ViewModel.Providers, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:ProviderItem">
                        <Border Padding="14"
                                Margin="0,0,0,8"
                                CornerRadius="8"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{x:Bind Name}"
                                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        <Border x:Uid="ScriptsBuiltinBadge"
                                                Padding="6,1"
                                                CornerRadius="4"
                                                VerticalAlignment="Center"
                                                Background="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                                                Visibility="{x:Bind Builtin, Converter={StaticResource BoolToVis}}">
                                            <TextBlock x:Uid="ScriptsBuiltinBadgeLabel"
                                                       Style="{StaticResource CaptionTextBlockStyle}" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{x:Bind Description}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="WrapWholeWords" />
                                    <TextBlock Text="{x:Bind GrantedSummary}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                               TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <Button x:Uid="ScriptsRemoveButton"
                                        Grid.Column="1"
                                        VerticalAlignment="Top"
                                        Tag="{x:Bind}"
                                        Click="OnRemoveProviderClick"
                                        IsEnabled="{x:Bind CanRemove}">
                                    <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Automation scripts -->
            <Grid ColumnSpacing="12" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Uid="ScriptsAutomationHeader"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Style="{StaticResource SubtitleTextBlockStyle}" />
                <Button x:Uid="ScriptsImportScriptButton"
                        Grid.Column="1"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="OnImportScriptClick">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE896;" FontSize="14" />
                        <TextBlock x:Uid="ScriptsImportScriptButtonLabel" />
                    </StackPanel>
                </Button>
            </Grid>

            <TextBlock x:Uid="ScriptsAutomationEmpty"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Visibility="{x:Bind ViewModel.Scripts.Count, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />

            <ItemsControl ItemsSource="{x:Bind ViewModel.Scripts, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:ScriptItem">
                        <Border Padding="14"
                                Margin="0,0,0,8"
                                CornerRadius="8"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="{x:Bind Name}"
                                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Text="{x:Bind Description}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="WrapWholeWords" />
                                    <TextBlock Text="{x:Bind GrantedSummary}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                               TextWrapping="WrapWholeWords" />
                                </StackPanel>
                                <ToggleSwitch x:Uid="ScriptsEnabledToggle"
                                              Grid.Column="1"
                                              VerticalAlignment="Center"
                                              IsOn="{x:Bind Enabled}"
                                              Tag="{x:Bind}"
                                              Toggled="OnScriptToggled" />
                                <Button x:Uid="ScriptsRemoveButton"
                                        Grid.Column="2"
                                        VerticalAlignment="Center"
                                        Tag="{x:Bind}"
                                        Click="OnRemoveScriptClick">
                                    <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Automation log -->
            <TextBlock x:Uid="ScriptsLogHeader"
                       Margin="0,8,0,0"
                       Style="{StaticResource SubtitleTextBlockStyle}" />
            <Border MinHeight="160"
                    MaxHeight="280"
                    CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <Grid>
                    <TextBlock x:Uid="ScriptsLogEmpty"
                               Margin="16"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Visibility="{x:Bind ViewModel.LogLines.Count, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{x:Bind ViewModel.LogLines, Mode=OneWay}"
                                      Padding="12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <TextBlock Text="{x:Bind}"
                                               FontFamily="Consolas"
                                               FontSize="12"
                                               IsTextSelectionEnabled="True"
                                               TextWrapping="Wrap" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
