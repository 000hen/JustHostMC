<?xml version="1.0" encoding="utf-8"?>
<controls:FluentContentDialog
    x:Class="JustHostMC.App.Views.PlayerDataDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:JustHostMC.App.Controls"
    xmlns:models="using:JustHostMC.App.Models"
    x:Uid="PlayerDataDialog"
    DefaultButton="Close"
    UseWideLayout="True">

    <Grid MaxHeight="720"
          HorizontalAlignment="Stretch"
          RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="2">
            <TextBlock x:Name="HeaderText"
                       Style="{StaticResource BodyStrongTextBlockStyle}" />
            <TextBlock x:Name="UuidText"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <ProgressBar x:Name="BusyBar" Grid.Row="1" IsIndeterminate="True" />

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16">
                <TextBlock x:Name="StatusText"
                           TextWrapping="Wrap"
                           Foreground="{ThemeResource SystemFillColorCriticalBrush}" />

                <StackPanel Spacing="8">
                    <TextBlock Text="{x:Bind InventoryHeader}"
                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <ListView ItemsSource="{x:Bind Inventory}"
                              SelectionMode="None"
                              MaxHeight="220">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:PlayerInventoryItemView">
                                <Grid Padding="8" ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{x:Bind SlotName}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind ItemId}"
                                               FontFamily="Consolas"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="2"
                                               Text="{x:Bind Count}"
                                               Style="{StaticResource CaptionTextBlockStyle}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock Text="{x:Bind EnderHeader}"
                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <ListView ItemsSource="{x:Bind EnderChest}"
                              SelectionMode="None"
                              MaxHeight="180">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:PlayerInventoryItemView">
                                <Grid Padding="8" ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{x:Bind SlotName}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind ItemId}"
                                               FontFamily="Consolas"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="2"
                                               Text="{x:Bind Count}"
                                               Style="{StaticResource CaptionTextBlockStyle}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <TextBox x:Name="RawBox"
                         Header="Raw player NBT"
                         FontFamily="Consolas"
                         FontSize="12"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="NoWrap"
                         Height="240" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</controls:FluentContentDialog>
