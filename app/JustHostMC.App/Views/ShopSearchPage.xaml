<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="JustHostMC.App.Views.ShopSearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:JustHostMC.App.Models"
    mc:Ignorable="d">

    <Grid Padding="16,8,16,0" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="{x:Bind ResultSummary(ViewModel.TotalResults, ViewModel.Query), Mode=OneWay}" />
            <ComboBox x:Name="SortCombo"
                      x:Uid="ShopSortCombo"
                      AutomationProperties.AutomationId="ShopSort"
                      Grid.Column="1"
                      MinWidth="160"
                      SelectedIndex="0"
                      SelectionChanged="OnSortChanged">
                <ComboBoxItem x:Uid="ShopSortRelevance" />
                <ComboBoxItem x:Uid="ShopSortDownloads" />
                <ComboBoxItem x:Uid="ShopSortFollows" />
                <ComboBoxItem x:Uid="ShopSortNewest" />
                <ComboBoxItem x:Uid="ShopSortUpdated" />
            </ComboBox>
        </Grid>

        <ListView Grid.Row="1"
                  ItemsSource="{x:Bind ViewModel.SearchResults, Mode=OneWay}"
                  SelectionMode="None"
                  IsItemClickEnabled="True"
                  ItemClick="OnItemClick"
                  IncrementalLoadingTrigger="Edge">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="8" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:ShopProjectItem">
                    <Grid ColumnSpacing="12"
                          Padding="0,6"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid Width="44" Height="44" VerticalAlignment="Top">
                            <FontIcon Glyph="&#xE7B8;" FontSize="18"
                                      Visibility="{x:Bind FallbackIconVisibility}" />
                            <Border CornerRadius="6" Visibility="{x:Bind IconVisibility}">
                                <Image Source="{x:Bind Icon}" Stretch="UniformToFill" />
                            </Border>
                        </Grid>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{x:Bind Title}"
                                           Style="{StaticResource BodyStrongTextBlockStyle}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{x:Bind Author}"
                                           Visibility="{x:Bind AuthorVisibility}"
                                           VerticalAlignment="Bottom"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            </StackPanel>
                            <TextBlock Text="{x:Bind Summary}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       MaxLines="2"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    Spacing="4"
                                    VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE896;" FontSize="11"
                                      Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            <TextBlock Text="{x:Bind DownloadsText}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <ProgressRing Grid.Row="1"
                      Width="40" Height="40"
                      IsActive="{x:Bind ViewModel.IsSearchLoading, Mode=OneWay}" />

        <TextBlock Grid.Row="1"
                   x:Uid="ShopSearchEmpty"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   Visibility="{x:Bind ShowEmpty(ViewModel.IsSearchLoading, ViewModel.TotalResults), Mode=OneWay}" />
    </Grid>
</Page>
