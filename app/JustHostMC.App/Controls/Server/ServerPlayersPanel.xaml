<UserControl
    x:Class="JustHostMC.App.Controls.Server.ServerPlayersPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:JustHostMC.App.Models"
    xmlns:server="using:JustHostMC.App.Controls.Server"
    mc:Ignorable="d">

    <Grid>
    <server:ServerSectionLayout
        Title="{x:Bind PlayersHeader(Players.Count), Mode=OneWay}"
        IconGlyph="&#xE716;">
        <server:ServerSectionLayout.HeaderContent>
            <Button
                x:Uid="ManageBansButton"
                VerticalAlignment="Center"
                Click="OnManageBansClick">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <SymbolIcon Symbol="BlockContact" />
                    <TextBlock x:Uid="ManageBansButtonLabel" />
                </StackPanel>
            </Button>
        </server:ServerSectionLayout.HeaderContent>
        <server:ServerSectionLayout.Body>
            <Grid RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid>
                <TextBlock
                    x:Uid="PlayersEmptyHint"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    TextWrapping="Wrap"
                    Visibility="{x:Bind HasNoPlayers(Players.Count), Mode=OneWay}" />
                <TextBlock
                    x:Uid="ServerSectionPlayersHint"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    TextWrapping="Wrap"
                    Visibility="{x:Bind HasPlayers(Players.Count), Mode=OneWay}" />
                </Grid>
                <ListView Grid.Row="1" ItemsSource="{x:Bind Players.Players, Mode=OneWay}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:PlayerItem">
                        <Grid MinHeight="48" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border
                                Grid.Column="0"
                                Width="32"
                                Height="32"
                                Margin="0,0,8,0"
                                Background="{ThemeResource ControlFillColorDefaultBrush}"
                                CornerRadius="4">
                                <Image
                                    Width="32"
                                    Height="32"
                                    Source="{x:Bind HeadImage}"
                                    Stretch="UniformToFill" />
                            </Border>
                            <TextBlock
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Text="{x:Bind Name}"
                                TextTrimming="CharacterEllipsis" />
                            <Button
                                x:Uid="PlayerActionsButton"
                                Grid.Column="2"
                                MinWidth="88"
                                Padding="10,6"
                                Tag="{x:Bind}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontSize="14" Glyph="&#xE712;" />
                                    <TextBlock x:Uid="PlayerActionsButtonLabel" />
                                </StackPanel>
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem
                                            x:Uid="PlayerOpMenuItem"
                                            Click="OnPlayerOpClick"
                                            Tag="{x:Bind}">
                                            <MenuFlyoutItem.Icon>
                                                <SymbolIcon Symbol="Permissions" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem
                                            x:Uid="PlayerDeopMenuItem"
                                            Click="OnPlayerDeopClick"
                                            Tag="{x:Bind}">
                                            <MenuFlyoutItem.Icon>
                                                <SymbolIcon Symbol="Permissions" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem
                                            x:Uid="PlayerKickMenuItem"
                                            Click="OnPlayerKickClick"
                                            Tag="{x:Bind}">
                                            <MenuFlyoutItem.Icon>
                                                <SymbolIcon Symbol="Cancel" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem
                                            x:Uid="PlayerBanMenuItem"
                                            Click="OnPlayerBanClick"
                                            Tag="{x:Bind}">
                                            <MenuFlyoutItem.Icon>
                                                <SymbolIcon Symbol="BlockContact" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutSeparator />
                                        <MenuFlyoutItem
                                            x:Uid="PlayerRawMenuItem"
                                            Click="OnPlayerRawClick"
                                            Tag="{x:Bind}">
                                            <MenuFlyoutItem.Icon>
                                                <SymbolIcon Symbol="View" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem
                                            x:Uid="PlayerInventoryMenuItem"
                                            Click="OnPlayerInventoryClick"
                                            Tag="{x:Bind}">
                                            <MenuFlyoutItem.Icon>
                                                <SymbolIcon Symbol="List" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </server:ServerSectionLayout.Body>
    </server:ServerSectionLayout>
        <ContentDialog
            x:Name="PlayerDialogHost"
            x:Uid="PlayerDialogHost"
            DefaultButton="Close" />
        <ContentDialog
            x:Name="BanListHostDialog"
            x:Uid="BanListHostDialog"
            DefaultButton="Close" />
    </Grid>
</UserControl>
