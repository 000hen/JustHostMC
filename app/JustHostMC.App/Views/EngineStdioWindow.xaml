<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="JustHostMC.App.Views.EngineStdioWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:JustHostMC.App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:JustHostMC.App.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <Grid x:Name="Root"
          Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="MonitorTitleBar">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="ms-appx:///Assets/StoreLogo.png" />
            </TitleBar.IconSource>
        </TitleBar>

        <controls:AdaptiveFilterLayout x:Name="MonitorLayout"
                                       Grid.Row="1"
                                       CompactPadding="12,8,12,8"
                                       WidePadding="12,8,12,8"
                                       RowSpacing="8"
                                       HeaderSpacing="10"
                                       CompactColumnSpacing="0"
                                       WideColumnSpacing="10"
                                       WideMinWidth="900"
                                       WideFilterWidth="250"
                                       CompactFilterMaxHeight="560"
                                       FilterRailCornerRadius="8"
                                       CompactFilterOpening="OnCompactFilterOpening">
            <controls:AdaptiveFilterLayout.HeaderContent>
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <ToggleButton x:Uid="EngineMonitorStopButton"
                                      Checked="OnPauseChanged"
                                      Unchecked="OnPauseChanged" />
                        <Button x:Uid="EngineMonitorClearButton" Click="OnClearClick">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                <TextBlock x:Uid="EngineMonitorClearButtonLabel" />
                            </StackPanel>
                        </Button>
                        <Button x:Uid="EngineMonitorCopyButton" Click="OnCopyClick">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8C8;" FontSize="14" />
                                <TextBlock x:Uid="EngineMonitorCopyButtonLabel" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <CheckBox x:Uid="EngineMonitorAutoScrollCheckBox"
                              x:Name="AutoScrollCheckBox"
                              Grid.Column="1"
                              Margin="4,0"
                              HorizontalAlignment="Left"
                              IsChecked="True" />
                </Grid>
            </controls:AdaptiveFilterLayout.HeaderContent>

            <controls:AdaptiveFilterLayout.MainContent>
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Grid>
                        <TextBlock x:Uid="EngineMonitorEmptyText"
                                   x:Name="EmptyText"
                                   Margin="24"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                        <ListView x:Name="LogListView"
                                  Padding="2"
                                  ItemsSource="{x:Bind VisibleEntries}"
                                  SelectionMode="None"
                                  Background="Transparent">
                            <ListView.ItemContainerTransitions>
                                <TransitionCollection />
                            </ListView.ItemContainerTransitions>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="MinHeight" Value="0" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="IsTabStop" Value="False" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:EngineStdioDisplayEntry">
                                    <StackPanel Padding="9,5" Spacing="1">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{x:Bind LevelLabel}"
                                                       FontFamily="Consolas"
                                                       FontSize="12"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="|"
                                                       FontFamily="Consolas"
                                                       FontSize="12"
                                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                            <TextBlock Text="{x:Bind StreamLabel}"
                                                       FontFamily="Consolas"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Text="|"
                                                       FontFamily="Consolas"
                                                       FontSize="12"
                                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                            <TextBlock Text="{x:Bind TimestampText}"
                                                       FontFamily="Consolas"
                                                       FontSize="12"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                        <TextBlock Text="{x:Bind Message}"
                                                   FontFamily="Consolas"
                                                   FontSize="12"
                                                   IsTextSelectionEnabled="True"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </controls:AdaptiveFilterLayout.MainContent>

            <controls:AdaptiveFilterLayout.CompactFilterContent>
                <StackPanel Width="270" Spacing="12">
                    <TextBlock x:Uid="EngineMonitorFiltersLabel"
                               Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBox x:Uid="EngineMonitorSearchBox"
                             x:Name="CompactSearchBox"
                             TextChanged="OnSearchTextChanged" />

                    <Rectangle Height="1"
                               Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                    <TextBlock x:Uid="EngineMonitorStreamsHeading"
                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <StackPanel Spacing="2">
                        <CheckBox x:Name="CompactStdOutCheckBox"
                                  Content="STDOUT"
                                  IsChecked="True"
                                  Checked="OnFilterChanged"
                                  Unchecked="OnFilterChanged" />
                        <CheckBox x:Name="CompactStdErrCheckBox"
                                  Content="STDERR"
                                  IsChecked="True"
                                  Checked="OnFilterChanged"
                                  Unchecked="OnFilterChanged" />
                        <CheckBox x:Name="CompactStdInCheckBox"
                                  Content="STDIN"
                                  IsChecked="True"
                                  Checked="OnFilterChanged"
                                  Unchecked="OnFilterChanged" />
                    </StackPanel>

                    <Rectangle Height="1"
                               Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                    <TextBlock x:Uid="EngineMonitorLevelsHeading"
                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <Grid RowSpacing="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <CheckBox x:Name="CompactDebugCheckBox"
                                  Content="DEBUG"
                                  IsChecked="True"
                                  Checked="OnFilterChanged"
                                  Unchecked="OnFilterChanged" />
                        <CheckBox x:Name="CompactInfoCheckBox"
                                  Grid.Column="1"
                                  Content="INFO"
                                  IsChecked="True"
                                  Checked="OnFilterChanged"
                                  Unchecked="OnFilterChanged" />
                        <CheckBox x:Name="CompactWarningCheckBox"
                                  Grid.Row="1"
                                  Content="WARN"
                                  IsChecked="True"
                                  Checked="OnFilterChanged"
                                  Unchecked="OnFilterChanged" />
                        <CheckBox x:Name="CompactErrorCheckBox"
                                  Grid.Row="1"
                                  Grid.Column="1"
                                  Content="ERROR"
                                  IsChecked="True"
                                  Checked="OnFilterChanged"
                                  Unchecked="OnFilterChanged" />
                    </Grid>
                    <TextBlock x:Uid="EngineMonitorStdinHint"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </controls:AdaptiveFilterLayout.CompactFilterContent>

            <controls:AdaptiveFilterLayout.WideFilterContent>
                <StackPanel Padding="14" Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE71C;" FontSize="14" />
                        <TextBlock x:Uid="EngineMonitorFiltersLabel"
                                   Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>
                    <TextBox x:Uid="EngineMonitorSearchBox"
                             x:Name="WideSearchBox"
                             TextChanged="OnSearchTextChanged" />

                    <Rectangle Height="1"
                               Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                    <TextBlock x:Uid="EngineMonitorStreamsHeading"
                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <StackPanel Spacing="2">
                        <CheckBox x:Name="WideStdOutCheckBox"
                                  Content="STDOUT"
                                  IsChecked="True"
                                  Checked="OnFilterChanged"
                                  Unchecked="OnFilterChanged" />
                        <CheckBox x:Name="WideStdErrCheckBox"
                                  Content="STDERR"
                                  IsChecked="True"
                                  Checked="OnFilterChanged"
                                  Unchecked="OnFilterChanged" />
                        <CheckBox x:Name="WideStdInCheckBox"
                                  Content="STDIN"
                                  IsChecked="True"
                                  Checked="OnFilterChanged"
                                  Unchecked="OnFilterChanged" />
                    </StackPanel>

                    <Rectangle Height="1"
                               Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                    <TextBlock x:Uid="EngineMonitorLevelsHeading"
                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <Grid RowSpacing="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <CheckBox x:Name="WideDebugCheckBox"
                                  Content="DEBUG"
                                  IsChecked="True"
                                  Checked="OnFilterChanged"
                                  Unchecked="OnFilterChanged" />
                        <CheckBox x:Name="WideInfoCheckBox"
                                  Grid.Column="1"
                                  Content="INFO"
                                  IsChecked="True"
                                  Checked="OnFilterChanged"
                                  Unchecked="OnFilterChanged" />
                        <CheckBox x:Name="WideWarningCheckBox"
                                  Grid.Row="1"
                                  Content="WARN"
                                  IsChecked="True"
                                  Checked="OnFilterChanged"
                                  Unchecked="OnFilterChanged" />
                        <CheckBox x:Name="WideErrorCheckBox"
                                  Grid.Row="1"
                                  Grid.Column="1"
                                  Content="ERROR"
                                  IsChecked="True"
                                  Checked="OnFilterChanged"
                                  Unchecked="OnFilterChanged" />
                    </Grid>
                    <TextBlock x:Uid="EngineMonitorStdinHint"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </controls:AdaptiveFilterLayout.WideFilterContent>

            <controls:AdaptiveFilterLayout.FooterContent>
                <TextBlock x:Name="StatusText"
                           Margin="4,0"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </controls:AdaptiveFilterLayout.FooterContent>
        </controls:AdaptiveFilterLayout>
    </Grid>
</Window>
