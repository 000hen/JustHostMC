<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="JustHostMC.App.Views.BackupsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:JustHostMC.App.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer
        MaxHeight="700"
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto">
        <Grid
            x:Name="BackupsRoot"
            HorizontalAlignment="Stretch"
            DataContext="{x:Bind ViewModel}"
            RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" ColumnSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Row="0"
                    Grid.Column="0"
                    Command="{x:Bind ViewModel.CreateBackupCommand}"
                    IsEnabled="{x:Bind ViewModel.CanRunActions, Mode=OneWay}"
                    Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="14" Glyph="&#xE710;" />
                        <TextBlock x:Uid="BackupCreateButtonLabel" />
                    </StackPanel>
                </Button>

                <Button
                    x:Uid="BackupOpenFolderButton"
                    Grid.Row="0"
                    Grid.Column="1"
                    VerticalAlignment="Stretch"
                    Click="OnOpenBackupFolderClick"
                    IsEnabled="{x:Bind ViewModel.CanRunActions, Mode=OneWay}">
                    <FontIcon FontSize="14" Glyph="&#xE8B7;" />
                </Button>

                <CheckBox
                    Grid.Row="1"
                    Grid.ColumnSpan="3"
                    IsChecked="{x:Bind ViewModel.SafeOnline, Mode=TwoWay}"
                    Visibility="{x:Bind ViewModel.ServerRunning, Converter={StaticResource BoolToVis}}">
                    <TextBlock x:Uid="BackupSafeOnlineLabel" TextWrapping="WrapWholeWords" />
                </CheckBox>
            </Grid>
            <ProgressBar
                Grid.Row="1"
                IsIndeterminate="True"
                Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVis}}" />

            <Border
                Grid.Row="2"
                MinHeight="320"
                MaxHeight="420"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid>
                    <TextBlock
                        x:Uid="BackupsEmptyHint"
                        Margin="24"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextAlignment="Center"
                        TextWrapping="WrapWholeWords"
                        Visibility="{x:Bind ViewModel.Backups.Count, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                    <ListView
                        Background="Transparent"
                        ItemsSource="{x:Bind ViewModel.Backups, Mode=OneWay}"
                        SelectionMode="None">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid
                                    Padding="12"
                                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                    BorderThickness="0,0,0,1"
                                    ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        Spacing="4">
                                        <TextBlock
                                            Style="{StaticResource BodyStrongTextBlockStyle}"
                                            Text="{Binding CreatedText}"
                                            TextTrimming="CharacterEllipsis" />
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                Grid.Column="0"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Text="{Binding SizeText}" />
                                            <TextBlock
                                                Grid.Column="1"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Text="{Binding Id}"
                                                TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </StackPanel>

                                    <Button
                                        x:Uid="BackupActionsButton"
                                        Grid.Column="1"
                                        MinWidth="92"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Tag="{Binding}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock x:Uid="BackupActionsButtonLabel" />
                                            <FontIcon FontSize="12" Glyph="&#xE70D;" />
                                        </StackPanel>
                                        <Button.Flyout>
                                            <MenuFlyout>
                                                <MenuFlyoutItem
                                                    x:Uid="BackupExportAction"
                                                    Click="OnExportBackupClick"
                                                    Tag="{Binding}">
                                                    <MenuFlyoutItem.Icon>
                                                        <FontIcon Glyph="&#xE896;" />
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>

                                                <MenuFlyoutItem
                                                    x:Uid="BackupRestoreAction"
                                                    Click="OnRestoreBackupConfirmClick"
                                                    Tag="{Binding}">
                                                    <MenuFlyoutItem.Icon>
                                                        <FontIcon Glyph="&#xE72C;" />
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>

                                                <MenuFlyoutSeparator />

                                                <MenuFlyoutItem
                                                    x:Uid="BackupDeleteAction"
                                                    Click="OnDeleteBackupConfirmClick"
                                                    Tag="{Binding}">
                                                    <MenuFlyoutItem.Icon>
                                                        <FontIcon Glyph="&#xE74D;" />
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                            </MenuFlyout>
                                        </Button.Flyout>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <TextBlock
                Grid.Row="3"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                TextWrapping="WrapWholeWords" />
        </Grid>
    </ScrollViewer>
</UserControl>
