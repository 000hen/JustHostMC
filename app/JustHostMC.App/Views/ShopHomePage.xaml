<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="JustHostMC.App.Views.ShopHomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:JustHostMC.App.Models"
    xmlns:local="using:JustHostMC.App.Views"
    mc:Ignorable="d">

    <Grid x:Name="RootLayout">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="CompactHome">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="ContentStack.Margin" Value="12,8,12,28" />
                        <Setter Target="SkeletonStack.Margin" Value="12,8,12,28" />
                        <Setter Target="WelcomePanel.Padding" Value="18" />
                        <Setter Target="WelcomePanel.MinHeight" Value="150" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="WideHome">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="900" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="ContentStack.Margin" Value="24,16,24,28" />
                        <Setter Target="SkeletonStack.Margin" Value="24,16,24,28" />
                        <Setter Target="WelcomePanel.Padding" Value="28" />
                        <Setter Target="WelcomePanel.MinHeight" Value="174" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <ScrollViewer VerticalScrollBarVisibility="Disabled"
                      HorizontalScrollBarVisibility="Disabled"
                      HorizontalContentAlignment="Stretch"
                      Visibility="{x:Bind LoadingVisibility(ViewModel.IsHomeLoading), Mode=OneWay}">
            <StackPanel x:Name="SkeletonStack"
                        MaxWidth="1440"
                        HorizontalAlignment="Stretch"
                        Margin="24,16,24,28"
                        Spacing="24"
                        Opacity="0.62">
                <Border Height="174"
                        Background="{ThemeResource ControlFillColorSecondaryBrush}"
                        CornerRadius="12">
                    <Grid Padding="28" ColumnSpacing="32">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="104" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center" Spacing="12">
                            <Border Width="380" Height="28"
                                    HorizontalAlignment="Left"
                                    Background="{ThemeResource ControlFillColorDefaultBrush}"
                                    CornerRadius="5" />
                            <Border Width="620" MaxWidth="620" Height="14"
                                    HorizontalAlignment="Left"
                                    Background="{ThemeResource ControlFillColorDefaultBrush}"
                                    CornerRadius="4" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Width="90" Height="30"
                                        Background="{ThemeResource ControlFillColorDefaultBrush}"
                                        CornerRadius="5" />
                                <Border Width="110" Height="30"
                                        Background="{ThemeResource ControlFillColorDefaultBrush}"
                                        CornerRadius="5" />
                            </StackPanel>
                        </StackPanel>
                        <Border Grid.Column="1"
                                Width="88"
                                Height="88"
                                CornerRadius="18"
                                Background="{ThemeResource ControlFillColorDefaultBrush}" />
                    </Grid>
                </Border>

                <StackPanel Spacing="12">
                    <StackPanel Spacing="7">
                        <Border Width="190" Height="20"
                                HorizontalAlignment="Left"
                                Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                CornerRadius="4" />
                        <Border Width="330" Height="12"
                                HorizontalAlignment="Left"
                                Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                CornerRadius="3" />
                    </StackPanel>
                    <ItemsRepeater ItemsSource="{x:Bind SkeletonItems}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="360"
                                               MinItemHeight="166"
                                               MinColumnSpacing="12"
                                               MinRowSpacing="12"
                                               ItemsStretch="Fill" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <Border Height="166"
                                        Padding="14"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="9">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="64" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="64" Height="64"
                                                VerticalAlignment="Top"
                                                Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                                CornerRadius="9" />
                                        <StackPanel Grid.Column="1" Spacing="9">
                                            <Border Width="170" Height="16"
                                                    HorizontalAlignment="Left"
                                                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                                    CornerRadius="4" />
                                            <Border Height="11"
                                                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                                    CornerRadius="3" />
                                            <Border Width="210" Height="11"
                                                    HorizontalAlignment="Left"
                                                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                                    CornerRadius="3" />
                                            <Border Width="90" Height="18"
                                                    HorizontalAlignment="Left"
                                                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                                    CornerRadius="8" />
                                        </StackPanel>
                                        <Border Grid.ColumnSpan="2"
                                                Width="120" Height="10"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Bottom"
                                                Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                                CornerRadius="3" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="8"
                    Visibility="{x:Bind HasStatus(ViewModel.StatusMessage), Mode=OneWay}">
            <FontIcon Glyph="&#xE783;"
                      FontSize="28"
                      Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      HorizontalContentAlignment="Stretch"
                      Visibility="{x:Bind local:ShopHomePage.InvertVisibility(ViewModel.IsHomeLoading), Mode=OneWay}">
            <StackPanel x:Name="ContentStack"
                        MaxWidth="1440"
                        HorizontalAlignment="Stretch"
                        Spacing="24"
                        Margin="24,16,24,28">
                <Border x:Name="WelcomeBanner"
                        Background="{ThemeResource AccentFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource AccentFillColorTertiaryBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                    <Grid x:Name="WelcomePanel" Padding="28" MinHeight="174">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel MaxWidth="650"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Spacing="10">
                            <TextBlock x:Uid="ShopDiscoverTitle"
                                       Style="{StaticResource TitleTextBlockStyle}"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Uid="ShopDiscoverSubtitle"
                                       FontSize="15"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ToggleButton IsChecked="{x:Bind ViewModel.UseVersionFilter, Mode=TwoWay}"
                                              Visibility="{x:Bind ViewModel.HasVersionFilter}"
                                              Click="OnFilterChanged">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE787;" FontSize="12" />
                                        <TextBlock Text="{x:Bind ViewModel.VersionFilterLabel}" />
                                    </StackPanel>
                                </ToggleButton>
                                <ToggleButton IsChecked="{x:Bind ViewModel.UseLoaderFilter, Mode=TwoWay}"
                                              Visibility="{x:Bind ViewModel.HasLoaderFilter}"
                                              Click="OnFilterChanged">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE713;" FontSize="12" />
                                        <TextBlock Text="{x:Bind ViewModel.LoaderFilterLabel}" />
                                    </StackPanel>
                                </ToggleButton>
                            </StackPanel>
                        </StackPanel>

                        <Grid Grid.Column="1" Margin="28,0,0,0">
                            <Image Source="ms-appx:///Assets/StoreLogo.png"
                                   Width="104"
                                   Height="104"
                                   Margin="0,14,14,0"
                                   Opacity="0.30" />
                            <Button x:Uid="ShopDismissWelcome"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Width="32"
                                    Height="32"
                                    Padding="0"
                                    Background="Transparent"
                                    Click="OnDismissWelcome">
                                <FontIcon Glyph="&#xE711;" FontSize="12" />
                            </Button>
                        </Grid>
                    </Grid>
                </Border>

                <ItemsControl ItemsSource="{x:Bind ViewModel.HomeSections, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:ShopSectionItem">
                            <StackPanel Spacing="12" Margin="0,0,0,24">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{x:Bind Title}"
                                               Style="{StaticResource SubtitleTextBlockStyle}" />
                                    <TextBlock Text="{x:Bind Description}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <ItemsRepeater ItemsSource="{x:Bind Projects}">
                                    <ItemsRepeater.Layout>
                                        <UniformGridLayout MinItemWidth="360"
                                                           MinItemHeight="166"
                                                           MinColumnSpacing="12"
                                                           MinRowSpacing="12"
                                                           ItemsStretch="Fill" />
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="models:ShopProjectItem">
                                            <Button Padding="0"
                                                    HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Stretch"
                                                    HorizontalContentAlignment="Stretch"
                                                    VerticalContentAlignment="Stretch"
                                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="9"
                                                    Click="OnProjectClick"
                                                    Tag="{x:Bind}">
                                                <Grid Padding="14" ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="64" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <Grid Width="64" Height="64" VerticalAlignment="Top">
                                                        <Border Background="{ThemeResource AccentFillColorTertiaryBrush}"
                                                                CornerRadius="9">
                                                            <TextBlock Text="{x:Bind Initial}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       FontSize="24"
                                                                       FontWeight="SemiBold"
                                                                       Visibility="{x:Bind FallbackIconVisibility}" />
                                                        </Border>
                                                        <Border CornerRadius="9"
                                                                Visibility="{x:Bind IconVisibility}">
                                                            <Image Source="{x:Bind Icon}" Stretch="UniformToFill" />
                                                        </Border>
                                                    </Grid>

                                                    <StackPanel Grid.Column="1" Spacing="4">
                                                        <TextBlock Text="{x:Bind Title}"
                                                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{x:Bind Summary}"
                                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                   TextWrapping="Wrap"
                                                                   MaxLines="3"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <StackPanel Orientation="Horizontal" Spacing="7">
                                                            <Border Padding="6,1"
                                                                    CornerRadius="8"
                                                                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                                                    Visibility="{x:Bind ProjectTypeVisibility}">
                                                                <TextBlock Text="{x:Bind ProjectTypeLabel}"
                                                                           Style="{StaticResource CaptionTextBlockStyle}" />
                                                            </Border>
                                                            <TextBlock Text="{x:Bind CategoriesText}"
                                                                       Visibility="{x:Bind CategoriesVisibility}"
                                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <Grid Grid.ColumnSpan="2"
                                                          VerticalAlignment="Bottom"
                                                          Margin="0,8,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{x:Bind Author}"
                                                                   Visibility="{x:Bind AuthorVisibility}"
                                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <StackPanel Grid.Column="1"
                                                                    Orientation="Horizontal"
                                                                    Spacing="4">
                                                            <FontIcon Glyph="&#xE896;"
                                                                      FontSize="10"
                                                                      Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                                            <TextBlock Text="{x:Bind DownloadsText}"
                                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
