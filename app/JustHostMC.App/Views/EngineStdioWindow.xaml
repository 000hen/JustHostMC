<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="JustHostMC.App.Views.EngineStdioWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:JustHostMC.App.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <Grid x:Name="Root"
          Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="MonitorTitleBar">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="ms-appx:///Assets/StoreLogo.png" />
            </TitleBar.IconSource>
        </TitleBar>

        <Grid Grid.Row="1" Padding="12" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Padding="8"
                    CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <Grid ColumnSpacing="12" RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="280" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Uid="EngineMonitorClearButton" Click="OnClearClick">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                <TextBlock x:Uid="EngineMonitorClearButtonLabel" />
                            </StackPanel>
                        </Button>
                        <Button x:Uid="EngineMonitorCopyButton" Click="OnCopyClick">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8C8;" FontSize="14" />
                                <TextBlock x:Uid="EngineMonitorCopyButtonLabel" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Spacing="10">
                        <CheckBox x:Name="StdOutCheckBox"
                                  Content="Stdout"
                                  IsChecked="True"
                                  Checked="OnFilterChanged"
                                  Unchecked="OnFilterChanged" />
                        <CheckBox x:Name="StdErrCheckBox"
                                  Content="Stderr"
                                  IsChecked="True"
                                  Checked="OnFilterChanged"
                                  Unchecked="OnFilterChanged" />
                        <CheckBox x:Name="StdInCheckBox"
                                  Content="Stdin"
                                  IsChecked="True"
                                  Checked="OnFilterChanged"
                                  Unchecked="OnFilterChanged" />
                        <ToggleButton x:Uid="EngineMonitorPauseButton"
                                      Checked="OnPauseChanged"
                                      Unchecked="OnPauseChanged" />
                        <CheckBox x:Uid="EngineMonitorAutoScrollCheckBox"
                                  x:Name="AutoScrollCheckBox"
                                  IsChecked="True" />
                    </StackPanel>

                    <TextBox x:Uid="EngineMonitorSearchBox"
                             x:Name="SearchBox"
                             Grid.Column="2"
                             HorizontalAlignment="Stretch"
                             TextChanged="OnSearchTextChanged" />

                    <TextBlock x:Uid="EngineMonitorStdinHint"
                               Grid.Row="1"
                               Grid.ColumnSpan="3"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap" />
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <Grid>
                    <TextBlock x:Uid="EngineMonitorEmptyText"
                               x:Name="EmptyText"
                               Margin="24"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                    <ListView x:Name="LogListView"
                              ItemsSource="{x:Bind VisibleEntries}"
                              SelectionMode="None"
                              Background="Transparent">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:EngineStdioDisplayEntry">
                                <Grid Padding="10,7" ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="78" />
                                        <ColumnDefinition Width="92" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{x:Bind StreamLabel}"
                                               FontFamily="Consolas"
                                               FontWeight="SemiBold"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind TimestampText}"
                                               FontFamily="Consolas"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Column="2"
                                               Text="{x:Bind Message}"
                                               FontFamily="Consolas"
                                               IsTextSelectionEnabled="True"
                                               TextWrapping="Wrap" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <TextBlock x:Name="StatusText"
                       Grid.Row="2"
                       Margin="4,0"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </Grid>
    </Grid>
</Window>
