<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="JustHostMC.App.Controls.InventoryItemDetails"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:services="using:JustHostMC.App.Services">
    <StackPanel Width="400" Spacing="12">
        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Image Width="52" Height="52" Source="{Binding Icon}" Stretch="Uniform" />
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding StyledName}" TextWrapping="Wrap" />
                <TextBlock FontFamily="Consolas" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding ItemId}" />
            </StackPanel>
        </Grid>

        <ItemsControl ItemsSource="{Binding NbtSections}">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="services:NbtDetailSection">
                    <StackPanel Margin="0,0,0,8" Spacing="7">
                        <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="{x:Bind Title}" />
                        <ItemsControl ItemsSource="{x:Bind Entries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="services:NbtDetailEntry">
                                    <Grid Margin="8,0,0,0" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Label}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind Value}" TextWrapping="Wrap" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <TextBlock
            x:Uid="InventoryItemDetailsNoCustomNbtText"
            FontStyle="Italic"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            TextWrapping="Wrap"
            Visibility="{Binding HasNoNbtDetails, Converter={StaticResource BoolToVis}}" />
        <TextBlock
            x:Uid="InventoryItemDetailsParseFailedText"
            FontStyle="Italic"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            TextWrapping="Wrap"
            Visibility="{Binding HasNbtParseFailure, Converter={StaticResource BoolToVis}}" />
        <Expander
            x:Uid="InventoryItemDetailsRawNbtExpander"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Stretch">
            <TextBox
                AcceptsReturn="True"
                FontFamily="Consolas"
                FontSize="11"
                HorizontalAlignment="Stretch"
                IsReadOnly="True"
                MaxHeight="260"
                Text="{Binding FormattedNbt}"
                TextWrapping="Wrap" />
        </Expander>
    </StackPanel>
</UserControl>
