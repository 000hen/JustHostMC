<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="JustHostMC.App.Views.ServerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:JustHostMC.App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:JustHostMC.App.Models"
    xmlns:server="using:JustHostMC.App.Controls.Server"
    mc:Ignorable="d">

    <Page.Resources>
        <ContentDialog
            x:Key="BackupsHostDialog"
            x:Uid="CommonCloseDialog"
            DefaultButton="Close"
            Style="{StaticResource DefaultContentDialogStyle}" />
        <ContentDialog
            x:Key="EditServerDialog"
            x:Uid="EditServerDialog"
            DefaultButton="Primary"
            Style="{StaticResource DefaultContentDialogStyle}" />
        <ContentDialog
            x:Key="RenameServerDialog"
            x:Uid="RenameServerDialog"
            DefaultButton="Primary">
            <TextBox x:Uid="RenameServerNameBox" />
        </ContentDialog>
        <ContentDialog
            x:Key="ServerFolderMissingDialog"
            x:Uid="ServerFolderMissingDialog"
            DefaultButton="Close" />
        <ContentDialog
            x:Key="DeleteServerDialog"
            x:Uid="DeleteServerDialog"
            DefaultButton="Close" />
    </Page.Resources>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <server:ServerHeaderPanel
            Grid.Row="0"
            BackupsClick="OnBackupsClick"
            DeleteClick="OnDeleteClick"
            EditClick="OnEditClick"
            OpenInstanceFolderClick="OnOpenInstanceFolderClick"
            Server="{x:Bind Server, Mode=OneWay}"
            StateButtonClick="OnStateButtonClick"
            TitleRenameClick="OnTitleRenameClick" />

        <Grid
            x:Name="DetailLayout"
            Grid.Row="1"
            Padding="24,12,24,24"
            RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <SelectorBar
                x:Name="SectionBar"
                Grid.Row="0"
                SelectionChanged="OnSectionChanged">
                <SelectorBarItem
                    x:Uid="ServerSectionConsole"
                    IsSelected="True"
                    Tag="console" />
                <SelectorBarItem x:Uid="ServerSectionPlayers" Tag="players" />
                <SelectorBarItem x:Uid="ServerSectionConfig" Tag="config" />
                <SelectorBarItem x:Uid="ServerSectionPerformance" Tag="performance" />
                <SelectorBarItem
                    x:Name="ModsSectionItem"
                    x:Uid="ServerSectionMods"
                    Tag="mods" />
            </SelectorBar>

            <Grid Grid.Row="1">

                <!--  Console  -->
                <server:ServerConsolePanel x:Name="ConsolePanel" Console="{x:Bind Console, Mode=OneWay}" />

                <!--  Players  -->
                <server:ServerPlayersPanel
                    x:Name="PlayersPanel"
                    Console="{x:Bind Console, Mode=OneWay}"
                    Players="{x:Bind Players, Mode=OneWay}"
                    Server="{x:Bind Server, Mode=OneWay}"
                    Visibility="Collapsed" />

                <!--  Configuration  -->
                <server:ServerConfigPanel
                    x:Name="ConfigPanel"
                    Config="{x:Bind Config, Mode=OneWay}"
                    Visibility="Collapsed" />

                <!--  Performance  -->
                <server:ServerPerformancePanel
                    x:Name="PerformancePanel"
                    Metrics="{x:Bind Metrics, Mode=OneWay}"
                    Visibility="Collapsed" />

                <!--  Plugins / Mods  -->
                <server:ServerModsPanel
                    x:Name="ModsPanel"
                    Mods="{x:Bind Mods, Mode=OneWay}"
                    Server="{x:Bind Server, Mode=OneWay}"
                    Visibility="Collapsed" />
            </Grid>

            <Border
                Grid.Row="2"
                Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="{x:Bind Server.ProgressTracker.IsActive, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <StackPanel Spacing="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="{x:Bind Server.ProgressTracker.CurrentStep, Mode=OneWay}" />
                        <Button
                            x:Uid="CommonDismissButton"
                            Grid.Column="1"
                            Command="{x:Bind Server.ProgressTracker.DismissCommand}"
                            Visibility="{x:Bind Server.ProgressTracker.HasFailed, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                    </Grid>
                    <ProgressBar IsIndeterminate="{x:Bind Server.ProgressTracker.IsIndeterminate, Mode=OneWay}" Value="{x:Bind Server.ProgressTracker.ProgressPercentage, Mode=OneWay}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
