<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="JustHostMC.App.Controls.AdaptiveFilterLayout"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="RootControl"
    Padding="12"
    mc:Ignorable="d">

    <Grid
        x:Name="RootLayout"
        Padding="{Binding Padding, ElementName=RootControl}"
        HorizontalAlignment="Stretch"
        RowSpacing="{Binding RowSpacing, ElementName=RootControl}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition x:Name="FilterColumn" Width="0" />
        </Grid.ColumnDefinitions>

        <Grid
            Grid.Row="0"
            Grid.Column="0"
            ColumnSpacing="{Binding HeaderSpacing, ElementName=RootControl}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ContentControl
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch"
                Content="{Binding HeaderContent, ElementName=RootControl}" />

            <Button
                x:Name="CompactFilterButton"
                Grid.Column="1"
                VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="14" Glyph="&#xE71C;" />
                    <TextBlock x:Uid="AdaptiveFilterLayoutFilterButtonLabel" />
                </StackPanel>
                <Button.Flyout>
                    <Flyout Opening="OnCompactFilterOpening" Placement="BottomEdgeAlignedRight">
                        <ScrollViewer
                            x:Name="CompactFilterScrollViewer"
                            MaxHeight="{Binding CompactFilterMaxHeight, ElementName=RootControl}"
                            HorizontalScrollBarVisibility="Disabled">
                            <ContentControl
                                x:Name="CompactFilterPresenter"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch" />
                        </ScrollViewer>
                    </Flyout>
                </Button.Flyout>
            </Button>
        </Grid>

        <ContentControl
            Grid.Row="1"
            Grid.Column="0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            HorizontalContentAlignment="Stretch"
            VerticalContentAlignment="Stretch"
            Content="{Binding MainContent, ElementName=RootControl}" />

        <Border
            x:Name="FilterRail"
            Grid.Row="1"
            Grid.Column="1"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="{Binding FilterRailCornerRadius, ElementName=RootControl}"
            Visibility="Collapsed">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                <ContentControl
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch"
                    Content="{Binding WideFilterContent, ElementName=RootControl}" />
            </ScrollViewer>
        </Border>

        <ContentControl
            Grid.Row="2"
            Grid.ColumnSpan="2"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            HorizontalContentAlignment="Stretch"
            VerticalContentAlignment="Stretch"
            Content="{Binding FooterContent, ElementName=RootControl}" />
    </Grid>
</UserControl>
