<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="JustHostMC.App.Views.BanListDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:JustHostMC.App.Models">

    <ScrollViewer MaxHeight="700"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <Grid HorizontalAlignment="Stretch"
              RowSpacing="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <InfoBar Grid.Row="0"
                     IsOpen="True"
                     IsClosable="False"
                     Severity="Informational"
                     Title="{x:Bind StoppedNoticeTitle}"
                     Message="{x:Bind StoppedNoticeMessage}"
                     Visibility="{x:Bind CanModify, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />

            <Border Grid.Row="1"
                    Padding="16"
                    CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="12">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0"
                                  Glyph="&#xE71B;"
                                  FontSize="18"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock x:Uid="BanListAddHeader"
                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock x:Uid="BanListAddHint"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Grid>

                    <Grid ColumnSpacing="10" RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <ComboBox x:Name="TypeBox"
                                  x:Uid="BanListTypeBox"
                                  Grid.Row="0"
                                  Grid.Column="0"
                                  SelectedIndex="0"
                                  IsEnabled="{x:Bind CanModify}">
                            <ComboBoxItem x:Uid="BanListTypePlayerItem" />
                            <ComboBoxItem x:Uid="BanListTypeIpItem" />
                        </ComboBox>

                        <TextBox x:Name="TargetBox"
                                 x:Uid="BanListTargetBox"
                                 Grid.Row="0"
                                 Grid.Column="1"
                                 IsEnabled="{x:Bind CanModify}" />

                        <TextBox x:Name="ReasonBox"
                                 x:Uid="BanListReasonBox"
                                 Grid.Row="1"
                                 Grid.ColumnSpan="2"
                                 MinHeight="104"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 IsEnabled="{x:Bind CanModify}" />

                        <Button Grid.Row="2"
                                Grid.ColumnSpan="2"
                                MinWidth="96"
                                HorizontalAlignment="Right"
                                Style="{StaticResource AccentButtonStyle}"
                                Click="OnAddClick"
                                IsEnabled="{x:Bind CanModify}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE710;" FontSize="14" />
                                <TextBlock x:Uid="BanListAddButtonLabel" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    MinHeight="320"
                    MaxHeight="420"
                    CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <Grid>
                    <TextBlock x:Name="EmptyHint"
                               x:Uid="BanListEmptyHint"
                               Margin="24"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="WrapWholeWords"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                    <ListView ItemsSource="{x:Bind Bans}"
                              SelectionMode="None"
                              Background="Transparent">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:BanEntryItem">
                                <Grid Padding="12" ColumnSpacing="12"
                                      BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                      BorderThickness="0,0,0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            MinWidth="64"
                                            Padding="8,4"
                                            CornerRadius="4"
                                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind TypeText}"
                                                   TextAlignment="Center"
                                                   Style="{StaticResource CaptionTextBlockStyle}" />
                                    </Border>

                                    <StackPanel Grid.Column="1"
                                                Spacing="3"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Target}"
                                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{x:Bind ReasonText}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{x:Bind CreatedText}"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{x:Bind IdentityText}"
                                                       FontFamily="Consolas"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </StackPanel>

                                    <Button Grid.Column="2"
                                            x:Uid="BanListRemoveButton"
                                            MinWidth="44"
                                            Padding="8"
                                            Tag="{Binding}"
                                            Click="OnRemoveClick"
                                            VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <StackPanel Grid.Row="3" Spacing="8">
                <ProgressBar x:Name="BusyBar"
                             IsIndeterminate="True"
                             Visibility="Collapsed" />
                <TextBlock x:Name="StatusText"
                           TextWrapping="WrapWholeWords"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
