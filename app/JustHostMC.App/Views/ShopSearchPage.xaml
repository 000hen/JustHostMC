<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="JustHostMC.App.Views.ShopSearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:JustHostMC.App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:JustHostMC.App.Models"
    xmlns:viewModels="using:JustHostMC.App.ViewModels"
    mc:Ignorable="d">

    <controls:SafeAreaContainer x:Name="SearchPageRoot">
        <controls:AdaptiveFilterLayout
            x:Name="SearchFilterLayout"
            CompactColumnSpacing="0"
            CompactFilterMaxHeight="620"
            CompactPadding="12,8,12,0"
            FilterRailCornerRadius="10"
            FilterRailIncludesHeader="True"
            HeaderSpacing="12"
            RowSpacing="12"
            WideColumnSpacing="20"
            WideFilterWidth="292"
            WideMinWidth="1050"
            WidePadding="24,16,24,0">
            <controls:AdaptiveFilterLayout.HeaderContent>
                <StackPanel Spacing="2">
                    <TextBlock x:Uid="ShopSearchResultsHeading" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ResultSummary(ViewModel.TotalResults, ViewModel.Query), Mode=OneWay}" />
                </StackPanel>
            </controls:AdaptiveFilterLayout.HeaderContent>

            <controls:AdaptiveFilterLayout.MainContent>
                <Grid>
                    <ListView
                        HorizontalContentAlignment="Stretch"
                        IncrementalLoadingTrigger="Edge"
                        IsItemClickEnabled="True"
                        ItemClick="OnItemClick"
                        ItemsSource="{x:Bind ViewModel.SearchResults, Mode=OneWay}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        SelectionMode="None">
                        <ListView.Footer>
                            <Grid Height="52" Visibility="{x:Bind ShowLoadMoreIndicator(ViewModel.IsSearchLoading, ViewModel.SearchResults.Count), Mode=OneWay}">
                                <ProgressRing
                                    Width="24"
                                    Height="24"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    IsActive="{x:Bind ViewModel.IsSearchLoading, Mode=OneWay}" />
                            </Grid>
                        </ListView.Footer>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,8" />
                                <Setter Property="CornerRadius" Value="8" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:ShopProjectItem">
                                <Grid
                                    MinHeight="106"
                                    Padding="14"
                                    ColumnSpacing="14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="76" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Grid
                                        Width="76"
                                        Height="76"
                                        VerticalAlignment="Top">
                                        <Border Background="{ThemeResource AccentFillColorTertiaryBrush}" CornerRadius="10">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontSize="28"
                                                FontWeight="SemiBold"
                                                Text="{x:Bind Initial}"
                                                Visibility="{x:Bind FallbackIconVisibility}" />
                                        </Border>
                                        <Border CornerRadius="10" Visibility="{x:Bind IconVisibility}">
                                            <Image Source="{x:Bind Icon}" Stretch="UniformToFill" />
                                        </Border>
                                    </Grid>

                                    <StackPanel Grid.Column="1" Spacing="5">
                                        <StackPanel Spacing="1">
                                            <TextBlock
                                                Style="{StaticResource SubtitleTextBlockStyle}"
                                                Text="{x:Bind Title}"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Text="{x:Bind AuthorLine}"
                                                TextTrimming="CharacterEllipsis"
                                                Visibility="{x:Bind AuthorVisibility}" />
                                        </StackPanel>
                                        <TextBlock
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            MaxLines="2"
                                            Text="{x:Bind Summary}"
                                            TextTrimming="CharacterEllipsis"
                                            TextWrapping="Wrap" />
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border
                                                Padding="7,2"
                                                Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                                CornerRadius="10"
                                                Visibility="{x:Bind ProjectTypeVisibility}">
                                                <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="{x:Bind ProjectTypeLabel}" />
                                            </Border>
                                            <TextBlock
                                                Grid.Column="1"
                                                VerticalAlignment="Center"
                                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Text="{x:Bind CategoriesText}"
                                                TextTrimming="CharacterEllipsis"
                                                Visibility="{x:Bind CategoriesVisibility}" />
                                        </Grid>
                                    </StackPanel>

                                    <Border
                                        Grid.Column="2"
                                        Padding="9,5"
                                        VerticalAlignment="Top"
                                        Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                        CornerRadius="12">
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <FontIcon
                                                FontSize="11"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Glyph="&#xE896;" />
                                            <TextBlock
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Text="{x:Bind DownloadsText}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <ItemsControl
                        ItemsSource="{x:Bind SkeletonItems}"
                        Opacity="0.62"
                        Visibility="{x:Bind ShowSkeleton(ViewModel.IsSearchLoading, ViewModel.SearchResults.Count), Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Height="106"
                                    Margin="0,0,0,8"
                                    Padding="14"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                    <Grid ColumnSpacing="14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="76" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="76" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            Width="76"
                                            Height="76"
                                            Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                            CornerRadius="10" />
                                        <StackPanel
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Spacing="9">
                                            <Border
                                                Width="220"
                                                Height="17"
                                                HorizontalAlignment="Left"
                                                Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                                CornerRadius="4" />
                                            <Border
                                                Height="11"
                                                Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                                CornerRadius="3" />
                                            <Border
                                                Width="360"
                                                Height="11"
                                                MaxWidth="360"
                                                HorizontalAlignment="Left"
                                                Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                                CornerRadius="3" />
                                            <Border
                                                Width="130"
                                                Height="17"
                                                HorizontalAlignment="Left"
                                                Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                                CornerRadius="8" />
                                        </StackPanel>
                                        <Border
                                            Grid.Column="2"
                                            Width="64"
                                            Height="24"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                            CornerRadius="12" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="10"
                        Visibility="{x:Bind ShowEmpty(ViewModel.IsSearchLoading, ViewModel.TotalResults), Mode=OneWay}">
                        <FontIcon
                            FontSize="32"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Glyph="&#xE721;" />
                        <TextBlock
                            x:Uid="ShopSearchEmpty"
                            MaxWidth="420"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextAlignment="Center"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </controls:AdaptiveFilterLayout.MainContent>

            <controls:AdaptiveFilterLayout.CompactFilterContent>
                <StackPanel Width="280" Spacing="16">
                    <TextBlock x:Uid="ShopFilterHeading" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <ComboBox
                        x:Name="CompactSortCombo"
                        x:Uid="ShopSortCombo"
                        HorizontalAlignment="Stretch"
                        SelectedIndex="0"
                        SelectionChanged="OnCompactSortChanged">
                        <ComboBoxItem x:Uid="ShopSortRelevance" />
                        <ComboBoxItem x:Uid="ShopSortDownloads" />
                        <ComboBoxItem x:Uid="ShopSortFollows" />
                        <ComboBoxItem x:Uid="ShopSortNewest" />
                        <ComboBoxItem x:Uid="ShopSortUpdated" />
                    </ComboBox>
                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                    <StackPanel Spacing="4">
                        <TextBlock x:Uid="ShopCompatibilityHeading" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock
                            x:Uid="ShopCompatibilityDescription"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                    <CheckBox
                        Click="OnVersionFilterChanged"
                        Content="{x:Bind ViewModel.VersionFilterLabel, Mode=OneWay}"
                        IsChecked="{x:Bind ViewModel.UseVersionFilter, Mode=TwoWay}"
                        Visibility="{x:Bind ViewModel.HasVersionFilter}" />
                    <CheckBox
                        Click="OnLoaderFilterChanged"
                        Content="{x:Bind ViewModel.LoaderFilterLabel, Mode=OneWay}"
                        IsChecked="{x:Bind ViewModel.UseLoaderFilter, Mode=TwoWay}"
                        Visibility="{x:Bind ViewModel.HasLoaderFilter}" />
                    <StackPanel Spacing="8" Visibility="{x:Bind BoolToVisibility(ViewModel.HasCategoryFilters), Mode=OneWay}">
                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                        <TextBlock x:Uid="ShopCategoriesHeading" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <ItemsControl ItemsSource="{x:Bind ViewModel.CategoryFilters, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:ShopCategoryFilter">
                                    <CheckBox
                                        Click="OnCategoryFilterChanged"
                                        Content="{x:Bind Label}"
                                        IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                        Tag="{x:Bind}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                    <Button
                        x:Uid="ShopResetFilters"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Click="OnResetFilters" />
                </StackPanel>
            </controls:AdaptiveFilterLayout.CompactFilterContent>

            <controls:AdaptiveFilterLayout.WideFilterContent>
                <StackPanel Padding="20" Spacing="18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            x:Uid="ShopFilterHeading"
                            VerticalAlignment="Center"
                            Style="{StaticResource SubtitleTextBlockStyle}" />
                        <Button
                            x:Uid="ShopResetFilters"
                            Grid.Column="1"
                            Padding="8,4"
                            Click="OnResetFilters" />
                    </Grid>

                    <ComboBox
                        x:Name="WideSortCombo"
                        x:Uid="ShopSortCombo"
                        HorizontalAlignment="Stretch"
                        SelectedIndex="0"
                        SelectionChanged="OnWideSortChanged">
                        <ComboBoxItem x:Uid="ShopSortRelevance" />
                        <ComboBoxItem x:Uid="ShopSortDownloads" />
                        <ComboBoxItem x:Uid="ShopSortFollows" />
                        <ComboBoxItem x:Uid="ShopSortNewest" />
                        <ComboBoxItem x:Uid="ShopSortUpdated" />
                    </ComboBox>

                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <StackPanel Spacing="6">
                        <TextBlock x:Uid="ShopSourceHeading" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <Border
                            Padding="10,8"
                            Background="{ThemeResource ControlFillColorSecondaryBrush}"
                            CornerRadius="6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="13" Glyph="&#xE8D4;" />
                                <TextBlock Text="{x:Bind ViewModel.SelectedShopName, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>
                        <TextBlock
                            x:Uid="ShopSourceDescription"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <StackPanel Spacing="5">
                        <TextBlock x:Uid="ShopCompatibilityHeading" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock
                            x:Uid="ShopCompatibilityDescription"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                    <CheckBox
                        Click="OnVersionFilterChanged"
                        Content="{x:Bind ViewModel.VersionFilterLabel, Mode=OneWay}"
                        IsChecked="{x:Bind ViewModel.UseVersionFilter, Mode=TwoWay}"
                        Visibility="{x:Bind ViewModel.HasVersionFilter}" />
                    <CheckBox
                        Click="OnLoaderFilterChanged"
                        Content="{x:Bind ViewModel.LoaderFilterLabel, Mode=OneWay}"
                        IsChecked="{x:Bind ViewModel.UseLoaderFilter, Mode=TwoWay}"
                        Visibility="{x:Bind ViewModel.HasLoaderFilter}" />

                    <StackPanel Spacing="8" Visibility="{x:Bind BoolToVisibility(ViewModel.HasCategoryFilters), Mode=OneWay}">
                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                        <StackPanel Spacing="4">
                            <TextBlock x:Uid="ShopCategoriesHeading" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock
                                x:Uid="ShopCategoriesDescription"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <ItemsControl ItemsSource="{x:Bind ViewModel.CategoryFilters, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:ShopCategoryFilter">
                                    <CheckBox
                                        Click="OnCategoryFilterChanged"
                                        Content="{x:Bind Label}"
                                        IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                        Tag="{x:Bind}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <InfoBar
                        x:Uid="ShopFilterHint"
                        IsClosable="False"
                        IsOpen="True"
                        Severity="Informational" />
                </StackPanel>
            </controls:AdaptiveFilterLayout.WideFilterContent>
        </controls:AdaptiveFilterLayout>
    </controls:SafeAreaContainer>
</Page>
