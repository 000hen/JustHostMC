<UserControl
    x:Class="JustHostMC.App.Controls.Server.ServerHeaderPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:JustHostMC.App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid
        Padding="24,18"
        Background="{ThemeResource LayerFillColorDefaultBrush}"
        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
        BorderThickness="0,0,0,1"
        ColumnSpacing="16"
        RowSpacing="12"
        SizeChanged="OnPanelSizeChanged">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Grid
            Grid.Row="0"
            Grid.Column="0"
            VerticalAlignment="Center"
            ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <controls:StatusDot
                Grid.Column="0"
                VerticalAlignment="Center"
                Status="{x:Bind Server.Status, Mode=OneWay}" />
            <StackPanel Grid.Column="1" Spacing="2">
                <Button
                    x:Uid="ServerTitleRenameButton"
                    MaxWidth="560"
                    Padding="0"
                    HorizontalAlignment="Left"
                    HorizontalContentAlignment="Left"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="OnTitleRenameClick">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock
                            x:Name="NameText"
                            MaxWidth="520"
                            VerticalAlignment="Center"
                            MaxLines="1"
                            Style="{StaticResource TitleTextBlockStyle}"
                            Text="{x:Bind Server.Name, Mode=OneWay}"
                            TextTrimming="CharacterEllipsis" />
                        <FontIcon
                            VerticalAlignment="Center"
                            FontSize="14"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Glyph="&#xE70F;" />
                    </StackPanel>
                </Button>
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="{x:Bind Server.StatusText, Mode=OneWay}" />
            </StackPanel>
        </Grid>

        <StackPanel
            Grid.Row="0"
            Grid.Column="1"
            VerticalAlignment="Center"
            Orientation="Horizontal"
            Spacing="8">
            <Button
                x:Name="StateButton"
                Height="40"
                MinWidth="128"
                Background="{x:Bind StateBrush(Server.Status), Mode=OneWay}"
                Click="OnStateButtonClick"
                Foreground="{x:Bind StateForeground(Server.Status), Mode=OneWay}"
                IsEnabled="{x:Bind StateEnabled(Server.Status), Mode=OneWay}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="16" Glyph="{x:Bind Server.StateActionGlyph, Mode=OneWay}" />
                    <TextBlock VerticalAlignment="Center" Text="{x:Bind Server.StateActionText, Mode=OneWay}" />
                </StackPanel>
            </Button>

            <Button x:Uid="ServerMoreButton" Height="40">
                <FontIcon FontSize="16" Glyph="&#xE712;" />
                <Button.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem x:Uid="ServerEditMenuItem" Click="OnEditClick">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE70F;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Uid="ServerBackupsMenuItem" Click="OnBackupsClick">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE8F7;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Uid="ServerOpenInstanceFolderMenuItem" Click="OnOpenInstanceFolderClick">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE8B7;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem x:Uid="ServerDeleteMenuItem" Click="OnDeleteClick">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE74D;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </Button.Flyout>
            </Button>
        </StackPanel>

        <Border
            Grid.Row="1"
            Grid.ColumnSpan="2"
            Padding="0"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <Grid x:Name="MetaGrid">
                <!--  Columns and Rows defined dynamically in code-behind  -->

                <Grid
                    x:Name="MetaType"
                    Padding="12,9"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    RowSpacing="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        x:Uid="ServerMetaTypeLabel"
                        Grid.Row="0"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBlock
                        Grid.Row="1"
                        Text="{x:Bind Server.TypeText, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                </Grid>

                <Grid
                    x:Name="MetaVersion"
                    Padding="12,9"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    RowSpacing="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        x:Uid="ServerMetaVersionLabel"
                        Grid.Row="0"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBlock
                        Grid.Row="1"
                        Text="{x:Bind Server.McVersion, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                </Grid>

                <Grid
                    x:Name="MetaPort"
                    Padding="12,9"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    RowSpacing="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        x:Uid="ServerMetaPortLabel"
                        Grid.Row="0"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBlock
                        Grid.Row="1"
                        Text="{x:Bind PortValueText(Server.Port), Mode=OneWay}"
                        TextWrapping="WrapWholeWords"
                        Visibility="{x:Bind HasPort(Server.Port), Mode=OneWay}" />
                    <TextBlock
                        x:Uid="ServerMetaPortAutoValue"
                        Grid.Row="1"
                        TextWrapping="WrapWholeWords"
                        Visibility="{x:Bind HasNoPort(Server.Port), Mode=OneWay}" />
                </Grid>

                <Grid
                    x:Name="MetaMemory"
                    Padding="12,9"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    RowSpacing="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        x:Uid="ServerMetaMemoryLabel"
                        Grid.Row="0"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBlock
                        Grid.Row="1"
                        Text="{x:Bind MemoryText(Server.MemoryMb), Mode=OneWay}"
                        TextWrapping="WrapWholeWords"
                        Visibility="{x:Bind HasMemory(Server.MemoryMb), Mode=OneWay}" />
                    <TextBlock
                        x:Uid="ServerMetaMemoryUnknownValue"
                        Grid.Row="1"
                        TextWrapping="WrapWholeWords"
                        Visibility="{x:Bind HasNoMemory(Server.MemoryMb), Mode=OneWay}" />
                </Grid>

            </Grid>
        </Border>
    </Grid>
</UserControl>
