<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="JustHostMC.App.Views.ServerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:JustHostMC.App.Controls"
    xmlns:server="using:JustHostMC.App.Controls.Server"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:JustHostMC.App.Models"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" SizeChanged="OnPageSizeChanged">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="Header"
            Grid.Row="0"
            Padding="24,18"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1"
            ColumnSpacing="16"
            RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Grid
                Grid.Row="0"
                Grid.Column="0"
                VerticalAlignment="Center"
                ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <controls:StatusDot
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Status="{x:Bind Server.Status, Mode=OneWay}" />
                <StackPanel Grid.Column="1" Spacing="2">
                    <Button
                        x:Uid="ServerTitleRenameButton"
                        MaxWidth="560"
                        Padding="0"
                        HorizontalAlignment="Left"
                        HorizontalContentAlignment="Left"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="OnTitleRenameClick">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock
                                x:Name="NameText"
                                MaxWidth="520"
                                VerticalAlignment="Center"
                                MaxLines="1"
                                Style="{StaticResource TitleTextBlockStyle}"
                                Text="{x:Bind Server.Name, Mode=OneWay}"
                                TextTrimming="CharacterEllipsis" />
                            <FontIcon
                                VerticalAlignment="Center"
                                FontSize="14"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Glyph="&#xE70F;" />
                        </StackPanel>
                    </Button>
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{x:Bind Server.StatusText, Mode=OneWay}" />
                </StackPanel>
            </Grid>

            <StackPanel
                Grid.Column="0"
                VerticalAlignment="Center"
                Spacing="2"
                Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <controls:StatusDot VerticalAlignment="Center" Status="{x:Bind Server.Status, Mode=OneWay}" />
                    <TextBlock
                        Style="{StaticResource TitleTextBlockStyle}"
                        Text="{x:Bind Server.Name, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <StackPanel
                    x:Name="MetaLine"
                    Margin="20,0,0,0"
                    Orientation="Horizontal"
                    Spacing="8">
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{x:Bind Server.TypeText, Mode=OneWay}" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="·" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{x:Bind Server.McVersion, Mode=OneWay}" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="·" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{x:Bind PortText(Server.Port), Mode=OneWay}" />
                </StackPanel>
            </StackPanel>

            <StackPanel
                Grid.Column="1"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="8">
                <Button
                    x:Name="StateButton"
                    Height="40"
                    MinWidth="128"
                    Background="{x:Bind StateBrush(Server.Status), Mode=OneWay}"
                    Click="OnStateButtonClick"
                    Foreground="{x:Bind StateForeground(Server.Status), Mode=OneWay}"
                    IsEnabled="{x:Bind StateEnabled(Server.Status), Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="16" Glyph="{x:Bind Server.StateActionGlyph, Mode=OneWay}" />
                        <TextBlock VerticalAlignment="Center" Text="{x:Bind Server.StateActionText, Mode=OneWay}" />
                    </StackPanel>
                </Button>

                <Button x:Uid="ServerMoreButton" Height="40">
                    <FontIcon FontSize="16" Glyph="&#xE712;" />
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuFlyoutItem x:Uid="ServerEditMenuItem" Click="OnEditClick">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE70F;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem x:Uid="ServerBackupsMenuItem" Click="OnBackupsClick">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE8F7;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem x:Uid="ServerOpenInstanceFolderMenuItem" Click="OnOpenInstanceFolderClick">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE8B7;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutSeparator />
                            <MenuFlyoutItem x:Uid="ServerDeleteMenuItem" Click="OnDeleteClick">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE74D;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
            </StackPanel>

            <Grid Grid.Row="1" Grid.ColumnSpan="2">
                <Border
                    x:Name="MetaWide"
                    Padding="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid
                            Grid.Column="0"
                            Padding="12,9"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="0,0,1,0"
                            RowSpacing="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                x:Uid="ServerMetaTypeLabel"
                                Grid.Row="0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock
                                Grid.Row="1"
                                Text="{x:Bind Server.TypeText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </Grid>

                        <Grid
                            Grid.Column="1"
                            Padding="12,9"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="0,0,1,0"
                            RowSpacing="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                x:Uid="ServerMetaVersionLabel"
                                Grid.Row="0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock
                                Grid.Row="1"
                                Text="{x:Bind Server.McVersion, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </Grid>

                        <Grid
                            Grid.Column="2"
                            Padding="12,9"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="0,0,1,0"
                            RowSpacing="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                x:Uid="ServerMetaPortLabel"
                                Grid.Row="0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock
                                Grid.Row="1"
                                Text="{x:Bind PortValueText(Server.Port), Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </Grid>

                        <Grid
                            Grid.Column="3"
                            Padding="12,9"
                            RowSpacing="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                x:Uid="ServerMetaMemoryLabel"
                                Grid.Row="0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock
                                Grid.Row="1"
                                Text="{x:Bind MemoryText(Server.MemoryMb), Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </Grid>
                    </Grid>
                </Border>

                <Border
                    x:Name="MetaMedium"
                    Padding="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid
                            Grid.Row="0"
                            Grid.Column="0"
                            Padding="12,9"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="0,0,1,1"
                            RowSpacing="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                x:Uid="ServerMetaTypeLabel"
                                Grid.Row="0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock
                                Grid.Row="1"
                                Text="{x:Bind Server.TypeText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </Grid>

                        <Grid
                            Grid.Row="0"
                            Grid.Column="1"
                            Padding="12,9"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="0,0,0,1"
                            RowSpacing="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                x:Uid="ServerMetaVersionLabel"
                                Grid.Row="0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock
                                Grid.Row="1"
                                Text="{x:Bind Server.McVersion, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </Grid>

                        <Grid
                            Grid.Row="1"
                            Grid.Column="0"
                            Padding="12,9"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="0,0,1,0"
                            RowSpacing="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                x:Uid="ServerMetaPortLabel"
                                Grid.Row="0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock
                                Grid.Row="1"
                                Text="{x:Bind PortValueText(Server.Port), Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </Grid>

                        <Grid
                            Grid.Row="1"
                            Grid.Column="1"
                            Padding="12,9"
                            RowSpacing="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                x:Uid="ServerMetaMemoryLabel"
                                Grid.Row="0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock
                                Grid.Row="1"
                                Text="{x:Bind MemoryText(Server.MemoryMb), Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </Grid>
                    </Grid>
                </Border>

                <Border
                    x:Name="MetaNarrow"
                    Padding="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid
                            Grid.Row="0"
                            Padding="12,9"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="0,0,0,1"
                            RowSpacing="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                x:Uid="ServerMetaTypeLabel"
                                Grid.Row="0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock
                                Grid.Row="1"
                                Text="{x:Bind Server.TypeText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </Grid>

                        <Grid
                            Grid.Row="1"
                            Padding="12,9"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="0,0,0,1"
                            RowSpacing="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                x:Uid="ServerMetaVersionLabel"
                                Grid.Row="0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock
                                Grid.Row="1"
                                Text="{x:Bind Server.McVersion, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </Grid>

                        <Grid
                            Grid.Row="2"
                            Padding="12,9"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="0,0,0,1"
                            RowSpacing="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                x:Uid="ServerMetaPortLabel"
                                Grid.Row="0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock
                                Grid.Row="1"
                                Text="{x:Bind PortValueText(Server.Port), Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </Grid>

                        <Grid
                            Grid.Row="3"
                            Padding="12,9"
                            RowSpacing="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                x:Uid="ServerMetaMemoryLabel"
                                Grid.Row="0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock
                                Grid.Row="1"
                                Text="{x:Bind MemoryText(Server.MemoryMb), Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Grid
            x:Name="DetailLayout"
            Grid.Row="1"
            Padding="24,12,24,24"
            RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <SelectorBar
                x:Name="SectionBar"
                Grid.Row="0"
                SelectionChanged="OnSectionChanged">
                <SelectorBarItem
                    x:Uid="ServerSectionConsole"
                    IsSelected="True"
                    Tag="console" />
                <SelectorBarItem x:Uid="ServerSectionPlayers" Tag="players" />
                <SelectorBarItem x:Uid="ServerSectionConfig" Tag="config" />
                <SelectorBarItem x:Uid="ServerSectionPerformance" Tag="performance" />
                <SelectorBarItem
                    x:Name="ModsSectionItem"
                    x:Uid="ServerSectionMods"
                    Tag="mods" />
            </SelectorBar>

            <Grid Grid.Row="1">

                <!--  Console  -->
                <server:ServerConsolePanel x:Name="ConsolePanel" Console="{x:Bind Console, Mode=OneWay}" />

                <!--  Players  -->
                <server:ServerPlayersPanel x:Name="PlayersPanel" Players="{x:Bind Players, Mode=OneWay}" Server="{x:Bind Server, Mode=OneWay}" Console="{x:Bind Console, Mode=OneWay}" Visibility="Collapsed" />

                <!--  Configuration  -->
                <server:ServerConfigPanel x:Name="ConfigPanel" Config="{x:Bind Config, Mode=OneWay}" Visibility="Collapsed" />

                <!--  Performance  -->
                <server:ServerPerformancePanel x:Name="PerformancePanel" Metrics="{x:Bind Metrics, Mode=OneWay}" Visibility="Collapsed" />

                <!--  Plugins / Mods  -->
                <server:ServerModsPanel x:Name="ModsPanel" Mods="{x:Bind Mods, Mode=OneWay}" Server="{x:Bind Server, Mode=OneWay}" Visibility="Collapsed" />
            </Grid>

            <Border
                Grid.Row="2"
                Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="{x:Bind Server.ProgressTracker.IsActive, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <StackPanel Spacing="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="{x:Bind Server.ProgressTracker.CurrentStep, Mode=OneWay}" />
                        <Button
                            x:Uid="InstallDismissButton"
                            Grid.Column="1"
                            Command="{x:Bind Server.ProgressTracker.DismissCommand}"
                            Visibility="{x:Bind Server.ProgressTracker.HasFailed, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                    </Grid>
                    <ProgressBar IsIndeterminate="{x:Bind Server.ProgressTracker.IsIndeterminate, Mode=OneWay}" Value="{x:Bind Server.ProgressTracker.ProgressPercentage, Mode=OneWay}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
