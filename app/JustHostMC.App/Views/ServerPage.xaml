<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="JustHostMC.App.Views.ServerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:JustHostMC.App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:JustHostMC.App.Models"
    mc:Ignorable="d">

    <Page.Resources>
        <DataTemplate x:Key="ModFileSkeletonTemplate">
            <Grid
                MinHeight="68"
                Padding="8"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                ColumnSpacing="12"
                Opacity="0.65">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border
                    Grid.Column="0"
                    Width="32"
                    Height="32"
                    VerticalAlignment="Center"
                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                    CornerRadius="4" />
                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Spacing="7">
                    <Border
                        Width="190"
                        Height="13"
                        HorizontalAlignment="Left"
                        Background="{ThemeResource ControlFillColorSecondaryBrush}"
                        CornerRadius="4" />
                    <Border
                        Width="310"
                        Height="10"
                        MaxWidth="310"
                        HorizontalAlignment="Left"
                        Background="{ThemeResource ControlFillColorSecondaryBrush}"
                        CornerRadius="3" />
                </StackPanel>
                <Border
                    Grid.Column="2"
                    Width="58"
                    Height="10"
                    VerticalAlignment="Center"
                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                    CornerRadius="3" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="ModFileRowTemplate" x:DataType="models:ModFileItem">
            <Grid
                Padding="8"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid
                    Grid.Column="0"
                    Width="32"
                    Height="32"
                    VerticalAlignment="Center">
                    <FontIcon
                        FontSize="16"
                        Glyph="&#xE7B8;"
                        Visibility="{x:Bind FallbackIconVisibility}" />
                    <Border CornerRadius="4" Visibility="{x:Bind IconVisibility}">
                        <Image Source="{x:Bind Icon}" Stretch="UniformToFill" />
                    </Border>
                </Grid>
                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Spacing="2">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            Text="{x:Bind Title}"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock
                            VerticalAlignment="Bottom"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="{x:Bind Name}"
                            TextTrimming="CharacterEllipsis"
                            Visibility="{x:Bind FileNameVisibility}" />
                    </StackPanel>
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{x:Bind InfoLine}"
                        TextTrimming="CharacterEllipsis"
                        Visibility="{x:Bind InfoLineVisibility}" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        MaxLines="2"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{x:Bind Description}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="Wrap"
                        Visibility="{x:Bind DescriptionVisibility}" />
                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="6"
                        Visibility="{x:Bind CompatibilityWarningVisibility}">
                        <FontIcon
                            FontSize="12"
                            Foreground="{ThemeResource SystemFillColorCautionBrush}"
                            Glyph="&#xE7BA;" />
                        <TextBlock
                            Foreground="{ThemeResource SystemFillColorCautionBrush}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="{x:Bind CompatibilityWarning}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="6"
                        Visibility="{x:Bind ParseErrorVisibility}">
                        <FontIcon
                            FontSize="12"
                            Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                            Glyph="&#xE783;" />
                        <TextBlock
                            Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="{x:Bind ParseError}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                    <HyperlinkButton
                        x:Uid="ModsWebsiteLink"
                        Padding="0"
                        FontSize="12"
                        NavigateUri="{x:Bind WebsiteUri}"
                        Visibility="{x:Bind WebsiteVisibility}" />
                </StackPanel>
                <TextBlock
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="{x:Bind SizeText}" />
                <Button x:Uid="ModsRemoveButton" Grid.Column="3">
                    <FontIcon FontSize="14" Glyph="&#xE74D;" />
                    <Button.Flyout>
                        <Flyout>
                            <StackPanel MaxWidth="240" Spacing="8">
                                <TextBlock x:Uid="ModsRemoveConfirmText" TextWrapping="Wrap" />
                                <Button
                                    x:Uid="ModsRemoveConfirmButton"
                                    HorizontalAlignment="Right"
                                    Click="OnRemoveModConfirm"
                                    Tag="{x:Bind}" />
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid x:Name="RootGrid" SizeChanged="OnPageSizeChanged">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="Header"
            Grid.Row="0"
            Padding="24,18"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1"
            ColumnSpacing="16"
            RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Grid
                Grid.Row="0"
                Grid.Column="0"
                VerticalAlignment="Center"
                ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <controls:StatusDot
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Status="{x:Bind Server.Status, Mode=OneWay}" />
                <StackPanel Grid.Column="1" Spacing="2">
                    <Button
                        x:Uid="ServerTitleRenameButton"
                        MaxWidth="560"
                        Padding="0"
                        HorizontalAlignment="Left"
                        HorizontalContentAlignment="Left"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="OnTitleRenameClick">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock
                                x:Name="NameText"
                                MaxWidth="520"
                                VerticalAlignment="Center"
                                MaxLines="1"
                                Style="{StaticResource TitleTextBlockStyle}"
                                Text="{x:Bind Server.Name, Mode=OneWay}"
                                TextTrimming="CharacterEllipsis" />
                            <FontIcon
                                VerticalAlignment="Center"
                                FontSize="14"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Glyph="&#xE70F;" />
                        </StackPanel>
                    </Button>
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{x:Bind Server.StatusText, Mode=OneWay}" />
                </StackPanel>
            </Grid>

            <StackPanel
                Grid.Column="0"
                VerticalAlignment="Center"
                Spacing="2"
                Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <controls:StatusDot VerticalAlignment="Center" Status="{x:Bind Server.Status, Mode=OneWay}" />
                    <TextBlock
                        Style="{StaticResource TitleTextBlockStyle}"
                        Text="{x:Bind Server.Name, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <StackPanel
                    x:Name="MetaLine"
                    Margin="20,0,0,0"
                    Orientation="Horizontal"
                    Spacing="8">
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{x:Bind Server.TypeText, Mode=OneWay}" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="·" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{x:Bind Server.McVersion, Mode=OneWay}" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="·" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{x:Bind PortText(Server.Port), Mode=OneWay}" />
                </StackPanel>
            </StackPanel>

            <StackPanel
                Grid.Column="1"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="8">
                <Button
                    x:Name="StateButton"
                    Height="40"
                    MinWidth="128"
                    Background="{x:Bind StateBrush(Server.Status), Mode=OneWay}"
                    Click="OnStateButtonClick"
                    Foreground="{x:Bind StateForeground(Server.Status), Mode=OneWay}"
                    IsEnabled="{x:Bind StateEnabled(Server.Status), Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="16" Glyph="{x:Bind Server.StateActionGlyph, Mode=OneWay}" />
                        <TextBlock VerticalAlignment="Center" Text="{x:Bind Server.StateActionText, Mode=OneWay}" />
                    </StackPanel>
                </Button>

                <Button x:Uid="ServerMoreButton" Height="40">
                    <FontIcon FontSize="16" Glyph="&#xE712;" />
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuFlyoutItem x:Uid="ServerEditMenuItem" Click="OnEditClick">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE70F;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem x:Uid="ServerBackupsMenuItem" Click="OnBackupsClick">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE8F7;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem x:Uid="ServerOpenInstanceFolderMenuItem" Click="OnOpenInstanceFolderClick">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE8B7;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutSeparator />
                            <MenuFlyoutItem x:Uid="ServerDeleteMenuItem" Click="OnDeleteClick">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE74D;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
            </StackPanel>

            <Grid Grid.Row="1" Grid.ColumnSpan="2">
                <Border
                    x:Name="MetaWide"
                    Padding="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid
                            Grid.Column="0"
                            Padding="12,9"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="0,0,1,0"
                            RowSpacing="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                x:Uid="ServerMetaTypeLabel"
                                Grid.Row="0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock
                                Grid.Row="1"
                                Text="{x:Bind Server.TypeText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </Grid>

                        <Grid
                            Grid.Column="1"
                            Padding="12,9"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="0,0,1,0"
                            RowSpacing="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                x:Uid="ServerMetaVersionLabel"
                                Grid.Row="0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock
                                Grid.Row="1"
                                Text="{x:Bind Server.McVersion, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </Grid>

                        <Grid
                            Grid.Column="2"
                            Padding="12,9"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="0,0,1,0"
                            RowSpacing="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                x:Uid="ServerMetaPortLabel"
                                Grid.Row="0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock
                                Grid.Row="1"
                                Text="{x:Bind PortValueText(Server.Port), Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </Grid>

                        <Grid
                            Grid.Column="3"
                            Padding="12,9"
                            RowSpacing="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                x:Uid="ServerMetaMemoryLabel"
                                Grid.Row="0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock
                                Grid.Row="1"
                                Text="{x:Bind MemoryText(Server.MemoryMb), Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </Grid>
                    </Grid>
                </Border>

                <Border
                    x:Name="MetaMedium"
                    Padding="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid
                            Grid.Row="0"
                            Grid.Column="0"
                            Padding="12,9"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="0,0,1,1"
                            RowSpacing="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                x:Uid="ServerMetaTypeLabel"
                                Grid.Row="0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock
                                Grid.Row="1"
                                Text="{x:Bind Server.TypeText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </Grid>

                        <Grid
                            Grid.Row="0"
                            Grid.Column="1"
                            Padding="12,9"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="0,0,0,1"
                            RowSpacing="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                x:Uid="ServerMetaVersionLabel"
                                Grid.Row="0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock
                                Grid.Row="1"
                                Text="{x:Bind Server.McVersion, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </Grid>

                        <Grid
                            Grid.Row="1"
                            Grid.Column="0"
                            Padding="12,9"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="0,0,1,0"
                            RowSpacing="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                x:Uid="ServerMetaPortLabel"
                                Grid.Row="0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock
                                Grid.Row="1"
                                Text="{x:Bind PortValueText(Server.Port), Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </Grid>

                        <Grid
                            Grid.Row="1"
                            Grid.Column="1"
                            Padding="12,9"
                            RowSpacing="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                x:Uid="ServerMetaMemoryLabel"
                                Grid.Row="0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock
                                Grid.Row="1"
                                Text="{x:Bind MemoryText(Server.MemoryMb), Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </Grid>
                    </Grid>
                </Border>

                <Border
                    x:Name="MetaNarrow"
                    Padding="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid
                            Grid.Row="0"
                            Padding="12,9"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="0,0,0,1"
                            RowSpacing="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                x:Uid="ServerMetaTypeLabel"
                                Grid.Row="0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock
                                Grid.Row="1"
                                Text="{x:Bind Server.TypeText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </Grid>

                        <Grid
                            Grid.Row="1"
                            Padding="12,9"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="0,0,0,1"
                            RowSpacing="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                x:Uid="ServerMetaVersionLabel"
                                Grid.Row="0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock
                                Grid.Row="1"
                                Text="{x:Bind Server.McVersion, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </Grid>

                        <Grid
                            Grid.Row="2"
                            Padding="12,9"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="0,0,0,1"
                            RowSpacing="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                x:Uid="ServerMetaPortLabel"
                                Grid.Row="0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock
                                Grid.Row="1"
                                Text="{x:Bind PortValueText(Server.Port), Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </Grid>

                        <Grid
                            Grid.Row="3"
                            Padding="12,9"
                            RowSpacing="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                x:Uid="ServerMetaMemoryLabel"
                                Grid.Row="0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock
                                Grid.Row="1"
                                Text="{x:Bind MemoryText(Server.MemoryMb), Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Grid
            x:Name="DetailLayout"
            Grid.Row="1"
            Padding="24,12,24,24"
            RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <SelectorBar
                x:Name="SectionBar"
                Grid.Row="0"
                SelectionChanged="OnSectionChanged">
                <SelectorBarItem
                    x:Uid="ServerSectionConsole"
                    IsSelected="True"
                    Tag="console" />
                <SelectorBarItem x:Uid="ServerSectionPlayers" Tag="players" />
                <SelectorBarItem x:Uid="ServerSectionConfig" Tag="config" />
                <SelectorBarItem x:Uid="ServerSectionPerformance" Tag="performance" />
                <SelectorBarItem
                    x:Name="ModsSectionItem"
                    x:Uid="ServerSectionMods"
                    Tag="mods" />
            </SelectorBar>

            <Grid Grid.Row="1">

                <!--  Console  -->
                <Grid x:Name="ConsolePanel" RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border
                        Grid.Row="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid
                                Grid.Row="0"
                                Padding="12"
                                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                BorderThickness="0,0,0,1"
                                ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <FontIcon
                                    Grid.Column="0"
                                    FontSize="16"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Glyph="&#xE756;" />
                                <Grid Grid.Column="1" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Uid="ConsoleOutputHeader" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Text="{x:Bind Console.ServerName, Mode=OneWay}"
                                        TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Grid>

                            <ScrollViewer
                                x:Name="ConsoleLogScroller"
                                Grid.Row="1"
                                Padding="8"
                                Background="{ThemeResource ControlFillColorDefaultBrush}">
                                <ItemsControl ItemsSource="{x:Bind Console.Lines}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock
                                                FontFamily="Consolas"
                                                FontSize="12"
                                                IsTextSelectionEnabled="True"
                                                Text="{Binding}"
                                                TextWrapping="Wrap" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                    <Grid Grid.Row="1" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            x:Name="CommandBox"
                            x:Uid="ConsoleInput"
                            Grid.Column="0"
                            Height="40"
                            KeyDown="OnCommandKeyDown"
                            Text="{x:Bind Console.CommandText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <Button
                            x:Uid="ConsoleSendCommandButton"
                            Grid.Column="1"
                            Height="40"
                            MinWidth="104"
                            Command="{x:Bind Console.SendCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="14" Glyph="&#xE724;" />
                                <TextBlock x:Uid="ConsoleSendButtonLabel" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>

                <!--  Players  -->
                <ScrollViewer
                    x:Name="PlayersPanel"
                    VerticalScrollBarVisibility="Auto"
                    Visibility="Collapsed">
                    <Border
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="12">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon
                                    Grid.Column="0"
                                    FontSize="16"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Glyph="&#xE716;" />
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="{x:Bind PlayersHeader(Players.Count), Mode=OneWay}" />
                                    <TextBlock
                                        x:Uid="PlayersEmptyHint"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Visibility="{x:Bind HasNoPlayers(Players.Count), Mode=OneWay}" />
                                </StackPanel>
                                <Button
                                    x:Uid="ManageBansButton"
                                    Grid.Column="2"
                                    VerticalAlignment="Center"
                                    Click="OnManageBansClick">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <SymbolIcon Symbol="BlockContact" />
                                        <TextBlock x:Uid="ManageBansButtonLabel" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <ListView
                                Background="Transparent"
                                ItemsSource="{x:Bind Players.Players, Mode=OneWay}"
                                SelectionMode="None">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="models:PlayerItem">
                                        <Grid
                                            MinHeight="48"
                                            Padding="8"
                                            ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border
                                                Grid.Column="0"
                                                Width="32"
                                                Height="32"
                                                Background="{ThemeResource ControlFillColorDefaultBrush}"
                                                CornerRadius="4">
                                                <Image
                                                    Width="32"
                                                    Height="32"
                                                    Source="{x:Bind HeadImage}"
                                                    Stretch="UniformToFill" />
                                            </Border>
                                            <TextBlock
                                                Grid.Column="1"
                                                VerticalAlignment="Center"
                                                Text="{x:Bind Name}"
                                                TextTrimming="CharacterEllipsis" />
                                            <Button
                                                x:Uid="PlayerActionsButton"
                                                Grid.Column="2"
                                                MinWidth="88"
                                                Padding="10,6"
                                                Tag="{x:Bind}">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <FontIcon FontSize="14" Glyph="&#xE712;" />
                                                    <TextBlock x:Uid="PlayerActionsButtonLabel" />
                                                </StackPanel>
                                                <Button.Flyout>
                                                    <MenuFlyout>
                                                        <MenuFlyoutItem
                                                            x:Uid="PlayerOpMenuItem"
                                                            Click="OnPlayerOpClick"
                                                            Tag="{x:Bind}">
                                                            <MenuFlyoutItem.Icon>
                                                                <SymbolIcon Symbol="Permissions" />
                                                            </MenuFlyoutItem.Icon>
                                                        </MenuFlyoutItem>
                                                        <MenuFlyoutItem
                                                            x:Uid="PlayerDeopMenuItem"
                                                            Click="OnPlayerDeopClick"
                                                            Tag="{x:Bind}">
                                                            <MenuFlyoutItem.Icon>
                                                                <SymbolIcon Symbol="Permissions" />
                                                            </MenuFlyoutItem.Icon>
                                                        </MenuFlyoutItem>
                                                        <MenuFlyoutItem
                                                            x:Uid="PlayerKickMenuItem"
                                                            Click="OnPlayerKickClick"
                                                            Tag="{x:Bind}">
                                                            <MenuFlyoutItem.Icon>
                                                                <SymbolIcon Symbol="Cancel" />
                                                            </MenuFlyoutItem.Icon>
                                                        </MenuFlyoutItem>
                                                        <MenuFlyoutItem
                                                            x:Uid="PlayerBanMenuItem"
                                                            Click="OnPlayerBanClick"
                                                            Tag="{x:Bind}">
                                                            <MenuFlyoutItem.Icon>
                                                                <SymbolIcon Symbol="BlockContact" />
                                                            </MenuFlyoutItem.Icon>
                                                        </MenuFlyoutItem>
                                                        <MenuFlyoutSeparator />
                                                        <MenuFlyoutItem
                                                            x:Uid="PlayerRawMenuItem"
                                                            Click="OnPlayerRawClick"
                                                            Tag="{x:Bind}">
                                                            <MenuFlyoutItem.Icon>
                                                                <SymbolIcon Symbol="View" />
                                                            </MenuFlyoutItem.Icon>
                                                        </MenuFlyoutItem>
                                                        <MenuFlyoutItem
                                                            x:Uid="PlayerInventoryMenuItem"
                                                            Click="OnPlayerInventoryClick"
                                                            Tag="{x:Bind}">
                                                            <MenuFlyoutItem.Icon>
                                                                <SymbolIcon Symbol="List" />
                                                            </MenuFlyoutItem.Icon>
                                                        </MenuFlyoutItem>
                                                    </MenuFlyout>
                                                </Button.Flyout>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>
                </ScrollViewer>

                <!--  Configuration  -->
                <Grid x:Name="ConfigPanel" Visibility="Collapsed">
                    <ScrollViewer
                        HorizontalContentAlignment="Stretch"
                        HorizontalScrollBarVisibility="Disabled"
                        HorizontalScrollMode="Disabled"
                        VerticalScrollBarVisibility="Auto">
                        <StackPanel
                            Padding="0,0,0,76"
                            HorizontalAlignment="Stretch"
                            Spacing="8">
                            <TextBlock
                                x:Uid="ConfigStoppedHint"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="Wrap"
                                Visibility="{x:Bind Config.CanModify, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />

                            <ProgressBar IsIndeterminate="True" Visibility="{x:Bind Config.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVis}}" />

                            <StackPanel Spacing="12" Visibility="{x:Bind Config.IsInitialLoading, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                <Expander
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    IsEnabled="False"
                                    IsExpanded="True">
                                    <Expander.Header>
                                        <StackPanel Spacing="8">
                                            <Border
                                                Width="180"
                                                Height="18"
                                                HorizontalAlignment="Left"
                                                Background="{ThemeResource ControlFillColorDefaultBrush}"
                                                CornerRadius="4" />
                                            <Border
                                                Width="360"
                                                Height="12"
                                                HorizontalAlignment="Left"
                                                Background="{ThemeResource ControlFillColorDefaultBrush}"
                                                CornerRadius="4" />
                                        </StackPanel>
                                    </Expander.Header>
                                    <StackPanel Padding="0,4,0,0" Spacing="10">
                                        <Grid MinHeight="64" ColumnSpacing="16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="88" />
                                                <ColumnDefinition Width="240" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel
                                                Grid.Column="0"
                                                VerticalAlignment="Center"
                                                Spacing="6">
                                                <Border
                                                    Width="180"
                                                    Height="14"
                                                    HorizontalAlignment="Left"
                                                    Background="{ThemeResource ControlFillColorDefaultBrush}"
                                                    CornerRadius="4" />
                                                <Border
                                                    Width="420"
                                                    Height="11"
                                                    HorizontalAlignment="Left"
                                                    Background="{ThemeResource ControlFillColorDefaultBrush}"
                                                    CornerRadius="4" />
                                                <Border
                                                    Width="140"
                                                    Height="11"
                                                    HorizontalAlignment="Left"
                                                    Background="{ThemeResource ControlFillColorDefaultBrush}"
                                                    CornerRadius="4" />
                                            </StackPanel>
                                            <Border
                                                Grid.Column="1"
                                                Width="56"
                                                Height="14"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Background="{ThemeResource ControlFillColorDefaultBrush}"
                                                CornerRadius="4" />
                                            <Border
                                                Grid.Column="2"
                                                Width="220"
                                                Height="32"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Background="{ThemeResource ControlFillColorDefaultBrush}"
                                                CornerRadius="4" />
                                        </Grid>
                                        <Grid MinHeight="64" ColumnSpacing="16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="88" />
                                                <ColumnDefinition Width="240" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel
                                                Grid.Column="0"
                                                VerticalAlignment="Center"
                                                Spacing="6">
                                                <Border
                                                    Width="220"
                                                    Height="14"
                                                    HorizontalAlignment="Left"
                                                    Background="{ThemeResource ControlFillColorDefaultBrush}"
                                                    CornerRadius="4" />
                                                <Border
                                                    Width="500"
                                                    Height="11"
                                                    HorizontalAlignment="Left"
                                                    Background="{ThemeResource ControlFillColorDefaultBrush}"
                                                    CornerRadius="4" />
                                                <Border
                                                    Width="160"
                                                    Height="11"
                                                    HorizontalAlignment="Left"
                                                    Background="{ThemeResource ControlFillColorDefaultBrush}"
                                                    CornerRadius="4" />
                                            </StackPanel>
                                            <Border
                                                Grid.Column="1"
                                                Width="52"
                                                Height="14"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Background="{ThemeResource ControlFillColorDefaultBrush}"
                                                CornerRadius="4" />
                                            <Border
                                                Grid.Column="2"
                                                Width="220"
                                                Height="32"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Background="{ThemeResource ControlFillColorDefaultBrush}"
                                                CornerRadius="4" />
                                        </Grid>
                                    </StackPanel>
                                </Expander>

                                <Expander
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    IsEnabled="False">
                                    <Expander.Header>
                                        <Border
                                            Width="140"
                                            Height="18"
                                            HorizontalAlignment="Left"
                                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                                            CornerRadius="4" />
                                    </Expander.Header>
                                </Expander>
                            </StackPanel>

                            <controls:ConfigSectionExpander
                                x:Uid="ConfigPropertiesSection"
                                IsExpanded="True"
                                ItemsSource="{x:Bind Config.Properties, Mode=OneWay}"
                                Visibility="{x:Bind Config.IsInitialLoading, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />

                            <controls:ConfigSectionExpander
                                x:Uid="ConfigGameRulesSection"
                                HasMessage="{x:Bind Config.HasGameRulesMessage, Mode=OneWay}"
                                ItemsSource="{x:Bind Config.GameRules, Mode=OneWay}"
                                Message="{x:Bind Config.GameRulesMessage, Mode=OneWay}"
                                Visibility="{x:Bind Config.IsInitialLoading, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />

                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{x:Bind Config.StatusMessage, Mode=OneWay}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </ScrollViewer>

                    <Border
                        Margin="12"
                        Padding="14,10"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Bottom"
                        Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Visibility="{x:Bind Config.HasModifiedConfiguration, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                x:Uid="ConfigModifiedText"
                                VerticalAlignment="Center"
                                Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <StackPanel
                                Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8">
                                <Button Click="OnDiscardConfigChangesClick" IsEnabled="{x:Bind Config.CanDiscardChanges, Mode=OneWay}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <SymbolIcon Symbol="Undo" />
                                        <TextBlock x:Uid="ConfigDiscardButtonLabel" />
                                    </StackPanel>
                                </Button>
                                <Button
                                    Click="OnSaveModifiedConfigClick"
                                    IsEnabled="{x:Bind Config.CanSaveModifiedConfiguration, Mode=OneWay}"
                                    Style="{StaticResource AccentButtonStyle}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <SymbolIcon Symbol="Save" />
                                        <TextBlock x:Uid="ConfigSaveModifiedButtonLabel" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!--  Performance  -->
                <ScrollViewer
                    x:Name="PerformancePanel"
                    VerticalScrollBarVisibility="Auto"
                    Visibility="Collapsed">
                    <Grid ColumnSpacing="12" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border
                            Grid.Row="0"
                            Grid.Column="0"
                            Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <StackPanel Spacing="8">
                                <TextBlock
                                    x:Uid="MetricsCpu"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}" />
                                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="{x:Bind Metrics.CpuText, Mode=OneWay}" />
                                <controls:Sparkline
                                    Height="56"
                                    StrokeBrush="{ThemeResource AccentFillColorDefaultBrush}"
                                    Values="{x:Bind Metrics.CpuSeries, Mode=OneWay}" />
                            </StackPanel>
                        </Border>

                        <Border
                            Grid.Row="0"
                            Grid.Column="1"
                            Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <StackPanel Spacing="8">
                                <TextBlock
                                    x:Uid="MetricsMemory"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}" />
                                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="{x:Bind Metrics.MemText, Mode=OneWay}" />
                                <controls:Sparkline
                                    Height="56"
                                    StrokeBrush="{ThemeResource SystemFillColorSuccessBrush}"
                                    Values="{x:Bind Metrics.MemSeries, Mode=OneWay}" />
                            </StackPanel>
                        </Border>

                        <Border
                            Grid.Row="0"
                            Grid.Column="2"
                            Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <StackPanel Spacing="8">
                                <TextBlock
                                    x:Uid="MetricsNetwork"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}" />
                                <TextBlock
                                    Style="{StaticResource SubtitleTextBlockStyle}"
                                    Text="{x:Bind Metrics.NetText, Mode=OneWay}"
                                    Visibility="{x:Bind Metrics.NetworkAvailable, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                                <controls:Sparkline
                                    Height="56"
                                    StrokeBrush="{ThemeResource SystemFillColorCautionBrush}"
                                    Values="{x:Bind Metrics.NetSeries, Mode=OneWay}"
                                    Visibility="{x:Bind Metrics.NetworkAvailable, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                                <TextBlock
                                    x:Uid="MetricsNetworkUnavailable"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    TextWrapping="Wrap"
                                    Visibility="{x:Bind Metrics.NetworkAvailable, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                            </StackPanel>
                        </Border>

                    </Grid>
                </ScrollViewer>

                <!--  Plugins / Mods  -->
                <ScrollViewer
                    x:Name="ModsPanel"
                    VerticalScrollBarVisibility="Auto"
                    Visibility="Collapsed">
                    <StackPanel Spacing="12">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Visibility="{x:Bind Mods.IsInitialLoading, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                                <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="{x:Bind Mods.KindLabel, Mode=OneWay}" />
                                <TextBlock
                                    x:Uid="ModsStoppedHint"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Visibility="{x:Bind Mods.CanModify, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                            </StackPanel>
                            <StackPanel
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Spacing="7"
                                Visibility="{x:Bind Mods.IsInitialLoading, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                <Border
                                    Width="150"
                                    Height="14"
                                    HorizontalAlignment="Left"
                                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                    CornerRadius="4" />
                                <Border
                                    Width="235"
                                    Height="10"
                                    HorizontalAlignment="Left"
                                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                    CornerRadius="3"
                                    Opacity="0.7" />
                            </StackPanel>
                            <StackPanel
                                Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                Visibility="{x:Bind Mods.IsInitialLoading, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                                <Button
                                    AutomationProperties.AutomationId="ModsExportAll"
                                    Click="OnExportModsClick"
                                    IsEnabled="{x:Bind Mods.Supported, Mode=OneWay}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontSize="14" Glyph="&#xE896;" />
                                        <TextBlock x:Uid="ModsExportAllLabel" />
                                    </StackPanel>
                                </Button>
                                <Button
                                    AutomationProperties.AutomationId="ModsBrowse"
                                    Click="OnBrowseShopClick"
                                    IsEnabled="{x:Bind Mods.Supported, Mode=OneWay}"
                                    Style="{StaticResource AccentButtonStyle}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontSize="14" Glyph="&#xE719;" />
                                        <TextBlock x:Uid="ModsBrowseLabel" />
                                    </StackPanel>
                                </Button>
                                <Button
                                    AutomationProperties.AutomationId="ModsAddJars"
                                    Click="OnUploadClick"
                                    IsEnabled="{x:Bind Mods.CanModify, Mode=OneWay}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontSize="14" Glyph="&#xE8E5;" />
                                        <TextBlock x:Uid="ModsUploadLabel" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                            <Border
                                Grid.Column="1"
                                Width="264"
                                Height="32"
                                Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                CornerRadius="4"
                                Visibility="{x:Bind Mods.IsInitialLoading, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                        </Grid>

                        <TextBlock
                            x:Uid="ModsUnsupportedHint"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap"
                            Visibility="{x:Bind Mods.Supported, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />

                        <ProgressBar IsIndeterminate="True" Visibility="{x:Bind Mods.ShowOperationProgress, Mode=OneWay, Converter={StaticResource BoolToVis}}" />

                        <ItemsControl
                            IsHitTestVisible="False"
                            ItemTemplate="{StaticResource ModFileSkeletonTemplate}"
                            ItemsSource="{x:Bind Mods.LoadingRows, Mode=OneWay}"
                            Visibility="{x:Bind Mods.IsInitialLoading, Mode=OneWay, Converter={StaticResource BoolToVis}}" />

                        <ItemsControl
                            ItemTemplate="{StaticResource ModFileRowTemplate}"
                            ItemsSource="{x:Bind Mods.Files, Mode=OneWay}"
                            Visibility="{x:Bind Mods.IsInitialLoading, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                            <ItemsControl.ItemContainerTransitions>
                                <TransitionCollection>
                                    <AddDeleteThemeTransition />
                                    <ReorderThemeTransition />
                                </TransitionCollection>
                            </ItemsControl.ItemContainerTransitions>
                        </ItemsControl>

                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Bind Mods.StatusMessage, Mode=OneWay}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Border
                Grid.Row="2"
                Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="{x:Bind Server.ProgressTracker.IsActive, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <StackPanel Spacing="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="{x:Bind Server.ProgressTracker.CurrentStep, Mode=OneWay}" />
                        <Button
                            x:Uid="InstallDismissButton"
                            Grid.Column="1"
                            Command="{x:Bind Server.ProgressTracker.DismissCommand}"
                            Visibility="{x:Bind Server.ProgressTracker.HasFailed, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                    </Grid>
                    <ProgressBar IsIndeterminate="{x:Bind Server.ProgressTracker.IsIndeterminate, Mode=OneWay}" Value="{x:Bind Server.ProgressTracker.ProgressPercentage, Mode=OneWay}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
