<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="JustHostMC.App.Views.ShopWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:grpc="using:McManager.Grpc"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <Grid x:Name="Root" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="ShopTitleBar"
            x:Uid="ShopWindowTitleBar"
            BackRequested="OnTitleBarBackRequested"
            IsBackButtonEnabled="False"
            IsBackButtonVisible="False">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="ms-appx:///Assets/StoreLogo.png" />
            </TitleBar.IconSource>
            <TitleBar.Content>
                <AutoSuggestBox
                    x:Name="SearchBox"
                    x:Uid="ShopSearchBox"
                    Width="320"
                    MinWidth="180"
                    MaxWidth="420"
                    VerticalAlignment="Center"
                    AutomationProperties.AutomationId="ShopSearch"
                    QueryIcon="Find"
                    QuerySubmitted="OnSearchSubmitted"
                    TextChanged="OnSearchTextChanged" />
            </TitleBar.Content>
        </TitleBar>

        <Grid
            x:Name="CommandBarGrid"
            Grid.Row="1"
            Padding="12,4"
            ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <SelectorBar
                x:Name="ShopSelector"
                VerticalAlignment="Center"
                SelectionChanged="OnShopSelectionChanged" />

            <StackPanel
                x:Name="FilterStack"
                Grid.Column="1"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="8">
                <ToggleButton
                    x:Name="VersionFilterToggle"
                    AutomationProperties.AutomationId="ShopVersionFilter"
                    Click="OnFilterChanged"
                    IsChecked="{x:Bind ViewModel.UseVersionFilter, Mode=TwoWay}"
                    Visibility="{x:Bind ViewModel.HasVersionFilter}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon
                            FontSize="12"
                            Glyph="&#xE73E;"
                            Visibility="{x:Bind ViewModel.UseVersionFilter, Mode=OneWay}" />
                        <TextBlock Text="{x:Bind ViewModel.VersionFilterLabel}" />
                    </StackPanel>
                </ToggleButton>
                <ToggleButton
                    x:Name="LoaderFilterToggle"
                    AutomationProperties.AutomationId="ShopLoaderFilter"
                    Click="OnFilterChanged"
                    IsChecked="{x:Bind ViewModel.UseLoaderFilter, Mode=TwoWay}"
                    Visibility="{x:Bind ViewModel.HasLoaderFilter}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon
                            FontSize="12"
                            Glyph="&#xE73E;"
                            Visibility="{x:Bind ViewModel.UseLoaderFilter, Mode=OneWay}" />
                        <TextBlock Text="{x:Bind ViewModel.LoaderFilterLabel}" />
                    </StackPanel>
                </ToggleButton>
            </StackPanel>
        </Grid>

        <InfoBar
            x:Name="KeyMissingBar"
            x:Uid="ShopKeyMissingBar"
            Grid.Row="2"
            Margin="16,0"
            VerticalAlignment="Top"
            Canvas.ZIndex="1"
            IsClosable="False"
            IsOpen="False"
            Severity="Warning" />

        <Frame
            x:Name="ContentFrame"
            Grid.Row="2"
            Navigated="OnFrameNavigated" />
    </Grid>
</Window>
