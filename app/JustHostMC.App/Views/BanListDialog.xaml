<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="JustHostMC.App.Views.BanListDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:JustHostMC.App.Models">

    <ScrollViewer
        MaxHeight="700"
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto">
        <Grid HorizontalAlignment="Stretch" RowSpacing="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <InfoBar
                x:Uid="BanListStoppedNotice"
                Grid.Row="0"
                IsClosable="False"
                IsOpen="True"
                Severity="Informational"
                Visibility="{x:Bind CanModify, Converter={StaticResource BoolToVis}, ConverterParameter=True}" />

            <Border
                Grid.Row="1"
                Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon
                            Grid.Column="0"
                            FontSize="18"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Glyph="&#xE71B;" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock x:Uid="BanListAddHeader" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock
                                x:Uid="BanListAddHint"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Grid>

                    <Grid ColumnSpacing="10" RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <ComboBox
                            x:Name="TypeBox"
                            x:Uid="BanListTypeBox"
                            Grid.Row="0"
                            Grid.Column="0"
                            IsEnabled="{x:Bind CanModify}"
                            SelectedIndex="0">
                            <ComboBoxItem x:Uid="BanListTypePlayerItem" />
                            <ComboBoxItem x:Uid="BanListTypeIpItem" />
                        </ComboBox>

                        <TextBox
                            x:Name="TargetBox"
                            x:Uid="BanListTargetBox"
                            Grid.Row="0"
                            Grid.Column="1"
                            IsEnabled="{x:Bind CanModify}" />

                        <TextBox
                            x:Name="ReasonBox"
                            x:Uid="BanListReasonBox"
                            Grid.Row="1"
                            Grid.ColumnSpan="2"
                            MinHeight="104"
                            AcceptsReturn="True"
                            IsEnabled="{x:Bind CanModify}"
                            TextWrapping="Wrap" />

                        <Button
                            Grid.Row="2"
                            Grid.ColumnSpan="2"
                            MinWidth="96"
                            HorizontalAlignment="Right"
                            Click="OnAddClick"
                            IsEnabled="{x:Bind CanModify}"
                            Style="{StaticResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="14" Glyph="&#xE710;" />
                                <TextBlock x:Uid="BanListAddButtonLabel" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <Border
                Grid.Row="2"
                MinHeight="320"
                MaxHeight="420"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid>
                    <TextBlock
                        x:Name="EmptyHint"
                        x:Uid="BanListEmptyHint"
                        Margin="24"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextAlignment="Center"
                        TextWrapping="WrapWholeWords" />

                    <ListView
                        Background="Transparent"
                        ItemsSource="{x:Bind Bans}"
                        SelectionMode="None">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:BanEntryItem">
                                <Grid
                                    Padding="12"
                                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                    BorderThickness="0,0,0,1"
                                    ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Border
                                        Grid.Column="0"
                                        MinWidth="64"
                                        Padding="8,4"
                                        VerticalAlignment="Center"
                                        Background="{ThemeResource ControlFillColorDefaultBrush}"
                                        CornerRadius="4">
                                        <Grid>
                                            <TextBlock
                                                x:Uid="BanListEntryIpTypeText"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                TextAlignment="Center"
                                                Visibility="{x:Bind IsIpBan, Converter={StaticResource BoolToVis}}" />
                                            <TextBlock
                                                x:Uid="BanListEntryPlayerTypeText"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                TextAlignment="Center"
                                                Visibility="{x:Bind IsIpBan, Converter={StaticResource BoolToVis}, ConverterParameter=True}" />
                                        </Grid>
                                    </Border>

                                    <StackPanel
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Spacing="3">
                                        <TextBlock
                                            Style="{StaticResource BodyStrongTextBlockStyle}"
                                            Text="{x:Bind Target}"
                                            TextTrimming="CharacterEllipsis" />
                                        <Grid>
                                            <TextBlock
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="{x:Bind Reason}"
                                                TextTrimming="CharacterEllipsis"
                                                Visibility="{x:Bind HasReason, Converter={StaticResource BoolToVis}}" />
                                            <TextBlock
                                                x:Uid="BanListEntryNoReasonText"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                TextTrimming="CharacterEllipsis"
                                                Visibility="{x:Bind HasReason, Converter={StaticResource BoolToVis}, ConverterParameter=True}" />
                                        </Grid>
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                Grid.Column="0"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Text="{x:Bind CreatedText}" />
                                            <TextBlock
                                                Grid.Column="1"
                                                FontFamily="Consolas"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Text="{x:Bind IdentityText}"
                                                TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </StackPanel>

                                    <Button
                                        x:Uid="BanListRemoveButton"
                                        Grid.Column="2"
                                        MinWidth="44"
                                        Padding="8"
                                        VerticalAlignment="Center"
                                        Click="OnRemoveClick"
                                        Tag="{Binding}">
                                        <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <StackPanel Grid.Row="3" Spacing="8">
                <ProgressBar
                    x:Name="BusyBar"
                    IsIndeterminate="True"
                    Visibility="Collapsed" />
                <TextBlock x:Name="LoadFailedText" x:Uid="BanListLoadFailedText" Visibility="Collapsed" />
                <TextBlock x:Name="TargetRequiredText" x:Uid="BanListTargetRequiredText" Visibility="Collapsed" />
                <TextBlock x:Name="AddFailedText" x:Uid="BanListAddFailedText" Visibility="Collapsed" />
                <TextBlock x:Name="StoppedRequiredText" x:Uid="BanListStoppedRequiredText" Visibility="Collapsed" />
                <TextBlock x:Name="RemoveFailedText" x:Uid="BanListRemoveFailedText" Visibility="Collapsed" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
