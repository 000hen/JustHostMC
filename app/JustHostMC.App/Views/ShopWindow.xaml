<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="JustHostMC.App.Views.ShopWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:grpc="using:McManager.Grpc"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <Grid x:Name="Root"
          Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="CompactWindow">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="SearchBox.Width" Value="220" />
                        <Setter Target="CommandBarGrid.Padding" Value="12,4" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="WideWindow">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="900" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="SearchBox.Width" Value="360" />
                        <Setter Target="CommandBarGrid.Padding" Value="16,8" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="ShopTitleBar"
                  IsBackButtonVisible="False"
                  IsBackButtonEnabled="False"
                  BackRequested="OnTitleBarBackRequested">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="ms-appx:///Assets/StoreLogo.png" />
            </TitleBar.IconSource>
            <TitleBar.Content>
                <AutoSuggestBox x:Name="SearchBox"
                                x:Uid="ShopSearchBox"
                                AutomationProperties.AutomationId="ShopSearch"
                                Width="320"
                                MinWidth="180"
                                MaxWidth="420"
                                VerticalAlignment="Center"
                                QueryIcon="Find"
                                TextChanged="OnSearchTextChanged"
                                QuerySubmitted="OnSearchSubmitted" />
            </TitleBar.Content>
        </TitleBar>

        <Grid x:Name="CommandBarGrid"
              Grid.Row="1"
              Padding="12,4"
              ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <SelectorBar x:Name="ShopSelector"
                         VerticalAlignment="Center"
                         SelectionChanged="OnShopSelectionChanged" />

            <StackPanel x:Name="FilterStack"
                        Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right"
                        Spacing="8">
                <ToggleButton x:Name="VersionFilterToggle"
                              AutomationProperties.AutomationId="ShopVersionFilter"
                              IsChecked="{x:Bind ViewModel.UseVersionFilter, Mode=TwoWay}"
                              Visibility="{x:Bind ViewModel.HasVersionFilter}"
                              Click="OnFilterChanged">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE73E;" FontSize="12"
                                  Visibility="{x:Bind ViewModel.UseVersionFilter, Mode=OneWay}" />
                        <TextBlock Text="{x:Bind ViewModel.VersionFilterLabel}" />
                    </StackPanel>
                </ToggleButton>
                <ToggleButton x:Name="LoaderFilterToggle"
                              AutomationProperties.AutomationId="ShopLoaderFilter"
                              IsChecked="{x:Bind ViewModel.UseLoaderFilter, Mode=TwoWay}"
                              Visibility="{x:Bind ViewModel.HasLoaderFilter}"
                              Click="OnFilterChanged">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE73E;" FontSize="12"
                                  Visibility="{x:Bind ViewModel.UseLoaderFilter, Mode=OneWay}" />
                        <TextBlock Text="{x:Bind ViewModel.LoaderFilterLabel}" />
                    </StackPanel>
                </ToggleButton>
            </StackPanel>
        </Grid>

        <InfoBar x:Name="KeyMissingBar"
                 x:Uid="ShopKeyMissingBar"
                 Grid.Row="2"
                 VerticalAlignment="Top"
                 Margin="16,0"
                 Severity="Warning"
                 IsClosable="False"
                 IsOpen="False"
                 Canvas.ZIndex="1" />

        <Frame x:Name="ContentFrame"
               Grid.Row="2"
               Navigated="OnFrameNavigated" />
    </Grid>
</Window>
