<controls:FluentContentDialog
    x:Class="JustHostMC.App.Views.PlayerDialogBase"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:JustHostMC.App.Controls"
    x:Uid="PlayerDialogBase"
    DefaultButton="Close"
    UseWideLayout="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="2" Margin="0,0,0,10">
            <TextBlock x:Name="HeaderText"
                       Style="{StaticResource BodyStrongTextBlockStyle}" />
            <TextBlock x:Name="UuidText"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <ContentPresenter Grid.Row="1" Content="{x:Bind InnerContent, Mode=OneWay}" />
    </Grid>
</controls:FluentContentDialog>
