<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="JustHostMC.App.Views.ShopDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:JustHostMC.App.Models"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Grid
        x:Name="RootLayout"
        Padding="12,8,12,0"
        RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--
            Wide detail layout: project actions and media stay in the compact
            left rail while long-form content gets the flexible right pane.
        -->
        <Grid x:Name="DetailLayout" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="RailColumn" Width="*" />
                <ColumnDefinition x:Name="DetailsColumn" Width="0" />
            </Grid.ColumnDefinitions>

            <Border
                x:Name="ProjectRail"
                Grid.RowSpan="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="Collapsed">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Padding="20" Spacing="16">
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid
                                Width="72"
                                Height="72"
                                VerticalAlignment="Top">
                                <FontIcon
                                    FontSize="28"
                                    Glyph="&#xE7B8;"
                                    Visibility="{x:Bind ViewModel.Card.FallbackIconVisibility, Mode=OneWay}" />
                                <Border CornerRadius="10" Visibility="{x:Bind ViewModel.Card.IconVisibility, Mode=OneWay}">
                                    <Image Source="{x:Bind ViewModel.Card.Icon, Mode=OneWay}" Stretch="UniformToFill" />
                                </Border>
                            </Grid>
                            <StackPanel
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Spacing="6">
                                <TextBlock
                                    MaxLines="2"
                                    Style="{StaticResource TitleTextBlockStyle}"
                                    Text="{x:Bind ViewModel.Card.Title, Mode=OneWay}"
                                    TextTrimming="CharacterEllipsis"
                                    TextWrapping="Wrap" />
                                <Border
                                    Padding="8,2"
                                    HorizontalAlignment="Left"
                                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                    CornerRadius="10">
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Text="{x:Bind ViewModel.SourceName}" />
                                </Border>
                            </StackPanel>
                        </Grid>

                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Bind ViewModel.Card.Summary, Mode=OneWay}"
                            TextWrapping="Wrap" />

                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <StackPanel
                                Orientation="Horizontal"
                                Spacing="5"
                                Visibility="{x:Bind ViewModel.Card.AuthorVisibility, Mode=OneWay}">
                                <FontIcon
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    Glyph="&#xE77B;" />
                                <TextBlock
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="{x:Bind ViewModel.Card.Author, Mode=OneWay}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <FontIcon
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    Glyph="&#xE896;" />
                                <TextBlock
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="{x:Bind ViewModel.Card.DownloadsText, Mode=OneWay}" />
                            </StackPanel>
                        </StackPanel>

                        <Button
                            x:Name="InstallLatestButton"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            AutomationProperties.AutomationId="ShopInstallLatest"
                            Click="OnInstallClick"
                            IsEnabled="{x:Bind ViewModel.CanInstallLatest, Mode=OneWay}"
                            Style="{StaticResource AccentButtonStyle}"
                            Tag="{x:Bind ViewModel.LatestRelease, Mode=OneWay}">
                            <Grid>
                                <TextBlock Text="{x:Bind ViewModel.InstallActionLabel, Mode=OneWay}" Visibility="{x:Bind ViewModel.IsWebsiteAction, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=True}" />
                                <TextBlock Text="{x:Bind ViewModel.WebsiteActionLabel, Mode=OneWay}" Visibility="{x:Bind ViewModel.IsWebsiteAction, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                            </Grid>
                        </Button>

                        <HyperlinkButton
                            x:Uid="ShopOpenWebsite"
                            Padding="0"
                            HorizontalAlignment="Left"
                            Click="OnOpenWebsite"
                            Visibility="{x:Bind HasUrl(ViewModel.WebsiteUrl), Mode=OneWay}" />

                        <FlipView
                            Height="210"
                            CornerRadius="8"
                            ItemsSource="{x:Bind ViewModel.Gallery, Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.HasGallery, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                            <FlipView.ItemTemplate>
                                <DataTemplate x:DataType="models:ShopGalleryItem">
                                    <Grid Background="{ThemeResource ControlFillColorSecondaryBrush}">
                                        <Image Source="{x:Bind Image}" Stretch="Uniform" />
                                        <Border
                                            Padding="12,6"
                                            VerticalAlignment="Bottom"
                                            Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                                            Visibility="{x:Bind TitleVisibility}">
                                            <TextBlock
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Text="{x:Bind Title}"
                                                TextTrimming="CharacterEllipsis" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </FlipView.ItemTemplate>
                        </FlipView>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!--
                In compact mode this project card is pinned above the active
                scroll surface. The gallery stays out of the sticky region.
            -->
            <Grid
                x:Name="CompactHeader"
                Grid.Row="0"
                RowSpacing="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="0" />
                </Grid.RowDefinitions>

                <Border
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Grid Padding="12" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="56" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="170" />
                        </Grid.ColumnDefinitions>

                        <Grid
                            Width="56"
                            Height="56"
                            VerticalAlignment="Top">
                            <FontIcon
                                FontSize="23"
                                Glyph="&#xE7B8;"
                                Visibility="{x:Bind ViewModel.Card.FallbackIconVisibility, Mode=OneWay}" />
                            <Border CornerRadius="8" Visibility="{x:Bind ViewModel.Card.IconVisibility, Mode=OneWay}">
                                <Image Source="{x:Bind ViewModel.Card.Icon, Mode=OneWay}" Stretch="UniformToFill" />
                            </Border>
                        </Grid>

                        <StackPanel Grid.Column="1" Spacing="3">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Style="{StaticResource SubtitleTextBlockStyle}"
                                    Text="{x:Bind ViewModel.Card.Title, Mode=OneWay}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Grid.Column="1"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="{x:Bind ViewModel.SourceName}"
                                    Visibility="Collapsed" />
                            </Grid>
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                MaxLines="2"
                                Text="{x:Bind ViewModel.Card.Summary, Mode=OneWay}"
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" Spacing="14">
                                <TextBlock
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="{x:Bind ViewModel.Card.Author, Mode=OneWay}"
                                    Visibility="{x:Bind ViewModel.Card.AuthorVisibility, Mode=OneWay}" />
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon
                                        FontSize="11"
                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                        Glyph="&#xE896;" />
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Text="{x:Bind ViewModel.Card.DownloadsText, Mode=OneWay}" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Spacing="8">
                            <Button
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                AutomationProperties.AutomationId="ShopInstallLatestCompact"
                                Click="OnInstallClick"
                                IsEnabled="{x:Bind ViewModel.CanInstallLatest, Mode=OneWay}"
                                Style="{StaticResource AccentButtonStyle}"
                                Tag="{x:Bind ViewModel.LatestRelease, Mode=OneWay}">
                                <Grid>
                                    <TextBlock Text="{x:Bind ViewModel.InstallActionLabel, Mode=OneWay}" Visibility="{x:Bind ViewModel.IsWebsiteAction, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=True}" />
                                    <TextBlock Text="{x:Bind ViewModel.WebsiteActionLabel, Mode=OneWay}" Visibility="{x:Bind ViewModel.IsWebsiteAction, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                                </Grid>
                            </Button>
                            <HyperlinkButton
                                x:Uid="ShopOpenWebsite"
                                Padding="0"
                                HorizontalAlignment="Center"
                                Click="OnOpenWebsite"
                                Visibility="{x:Bind HasUrl(ViewModel.WebsiteUrl), Mode=OneWay}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <FlipView
                    Grid.Row="1"
                    Height="150"
                    CornerRadius="8"
                    ItemsSource="{x:Bind ViewModel.Gallery, Mode=OneWay}"
                    Visibility="Collapsed">
                    <FlipView.ItemTemplate>
                        <DataTemplate x:DataType="models:ShopGalleryItem">
                            <Grid Background="{ThemeResource ControlFillColorSecondaryBrush}">
                                <Image Source="{x:Bind Image}" Stretch="Uniform" />
                            </Grid>
                        </DataTemplate>
                    </FlipView.ItemTemplate>
                </FlipView>

            </Grid>

            <Grid
                x:Name="RightPane"
                Grid.Row="1"
                Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <InfoBar
                    Grid.Row="0"
                    IsClosable="False"
                    IsOpen="{x:Bind ViewModel.HasProjectCompatWarning, Mode=OneWay}"
                    Message="{x:Bind ViewModel.ProjectCompatMessage, Mode=OneWay}"
                    Severity="Warning" />

                <SelectorBar
                    x:Name="TabBar"
                    Grid.Row="1"
                    SelectionChanged="OnTabChanged">
                    <SelectorBarItem
                        x:Name="OverviewTab"
                        x:Uid="ShopOverviewTab"
                        IsSelected="True" />
                    <SelectorBarItem x:Name="VersionsTab" x:Uid="ShopVersionsTab" />
                </SelectorBar>

                <!--  Details  -->
                <Grid x:Name="OverviewPanel" Grid.Row="2">
                    <ProgressRing
                        Width="40"
                        Height="40"
                        IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
                    <WebView2 x:Name="BodyView" Visibility="{x:Bind BodyVisibility(ViewModel.IsLoading, ViewModel.BodyHtml), Mode=OneWay}" />
                </Grid>

                <!--  Versions  -->
                <Grid
                    x:Name="VersionsPanel"
                    Grid.Row="2"
                    Visibility="Collapsed">
                    <ListView ItemsSource="{x:Bind ViewModel.Versions, Mode=OneWay}" SelectionMode="None">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:ShopVersionItem">
                                <Grid
                                    Padding="0,10"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="0,0,0,1"
                                    ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border
                                        Padding="8,2"
                                        VerticalAlignment="Center"
                                        Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                        CornerRadius="10"
                                        Visibility="{x:Bind ChannelVisibility}">
                                        <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="{x:Bind ChannelText}" />
                                    </Border>
                                    <StackPanel
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Spacing="2">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock
                                                Style="{StaticResource BodyStrongTextBlockStyle}"
                                                Text="{x:Bind Name}"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                VerticalAlignment="Bottom"
                                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Text="{x:Bind VersionNumber}" />
                                            <FontIcon
                                                x:Uid="ShopCompatLoaderMismatchIcon"
                                                VerticalAlignment="Center"
                                                FontSize="14"
                                                Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                                Glyph="&#xE7BA;"
                                                Visibility="{x:Bind LoaderMismatchVisibility}" />
                                            <FontIcon
                                                x:Uid="ShopCompatVersionMismatchIcon"
                                                VerticalAlignment="Center"
                                                FontSize="14"
                                                Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                                Glyph="&#xE7BA;"
                                                Visibility="{x:Bind VersionMismatchVisibility}" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <TextBlock
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Text="{x:Bind GameVersionsText}" />
                                            <TextBlock
                                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Text="{x:Bind InfoLine}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <Button
                                        Grid.Column="2"
                                        VerticalAlignment="Center"
                                        Click="OnInstallClick"
                                        IsEnabled="{x:Bind ActionEnabled, Mode=OneWay}"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Tag="{x:Bind}">
                                        <Grid>
                                            <TextBlock x:Uid="ShopInstallActionText" Visibility="{x:Bind InstallActionVisibility, Mode=OneWay}" />
                                            <TextBlock x:Uid="ShopCreateServerActionText" Visibility="{x:Bind CreateServerActionVisibility, Mode=OneWay}" />
                                            <TextBlock Text="{x:Bind ActionLabel, Mode=OneWay}" Visibility="{x:Bind WebsiteActionVisibility, Mode=OneWay}" />
                                        </Grid>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <ProgressRing
                        Width="40"
                        Height="40"
                        IsActive="{x:Bind ViewModel.IsVersionsLoading, Mode=OneWay}" />
                    <TextBlock
                        x:Uid="ShopNoVersions"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Visibility="{x:Bind ShowNoVersions(ViewModel.IsVersionsLoading, ViewModel.Versions.Count), Mode=OneWay}" />
                </Grid>
            </Grid>
        </Grid>

        <!--  Install progress / status  -->
        <StackPanel
            Grid.Row="1"
            Margin="0,0,0,12"
            Spacing="8">
            <ProgressBar
                Maximum="100"
                Value="{x:Bind ProgressPercent(ViewModel.InstallProgress), Mode=OneWay}"
                Visibility="{x:Bind ViewModel.IsInstalling, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
            <InfoBar
                IsClosable="False"
                IsOpen="{x:Bind ViewModel.HasStatus, Mode=OneWay}"
                Severity="{x:Bind StatusSeverity(ViewModel.InstallSucceeded), Mode=OneWay}">
                <InfoBar.Content>
                    <StackPanel>
                        <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" />
                        <TextBlock x:Uid="ShopStatusLoadFailed" Visibility="{x:Bind ViewModel.IsLoadFailedStatus, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                        <TextBlock x:Uid="ShopStatusInstallDone" Visibility="{x:Bind ViewModel.IsInstallDoneStatus, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                        <TextBlock x:Uid="ShopStatusInstallFailed" Visibility="{x:Bind ViewModel.IsInstallFailedStatus, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>
                </InfoBar.Content>
            </InfoBar>
        </StackPanel>
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="CompactDetail">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="RootLayout.Padding" Value="12,8,12,0" />
                        <Setter Target="DetailLayout.ColumnSpacing" Value="0" />
                        <Setter Target="DetailLayout.RowSpacing" Value="12" />
                        <Setter Target="RailColumn.Width" Value="*" />
                        <Setter Target="DetailsColumn.Width" Value="0" />
                        <Setter Target="ProjectRail.Visibility" Value="Collapsed" />
                        <Setter Target="CompactHeader.Visibility" Value="Visible" />
                        <Setter Target="RightPane.(Grid.Column)" Value="0" />
                        <Setter Target="RightPane.(Grid.Row)" Value="1" />
                        <Setter Target="RightPane.(Grid.RowSpan)" Value="1" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="WideDetail">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1000" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="RootLayout.Padding" Value="24,16,24,0" />
                        <Setter Target="DetailLayout.ColumnSpacing" Value="24" />
                        <Setter Target="DetailLayout.RowSpacing" Value="0" />
                        <Setter Target="RailColumn.Width" Value="340" />
                        <Setter Target="DetailsColumn.Width" Value="*" />
                        <Setter Target="ProjectRail.Visibility" Value="Visible" />
                        <Setter Target="CompactHeader.Visibility" Value="Collapsed" />
                        <Setter Target="RightPane.(Grid.Column)" Value="1" />
                        <Setter Target="RightPane.(Grid.Row)" Value="0" />
                        <Setter Target="RightPane.(Grid.RowSpan)" Value="2" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
    </Grid>
</Page>
