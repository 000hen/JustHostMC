<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="JustHostMC.App.Controls.ConfigEntryEditor"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="Root"
    mc:Ignorable="d">

    <Grid Padding="0,8" ColumnSpacing="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="220" />
        </Grid.ColumnDefinitions>

        <StackPanel
            Grid.Column="0"
            VerticalAlignment="Center"
            Spacing="4">
            <TextBlock
                Style="{StaticResource BodyStrongTextBlockStyle}"
                Text="{Binding Entry.DisplayName, ElementName=Root}"
                TextTrimming="CharacterEllipsis" />
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                MaxLines="2"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="{Binding Entry.Description, ElementName=Root}"
                TextWrapping="WrapWholeWords"
                Visibility="{Binding Entry.HasDescription, ElementName=Root, Converter={StaticResource BoolToVis}}" />
            <TextBlock
                FontFamily="Consolas"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="{Binding Entry.Key, ElementName=Root}"
                TextTrimming="CharacterEllipsis" />
        </StackPanel>

        <Grid
            Grid.Column="1"
            VerticalAlignment="Center">
            <TextBlock
                x:Uid="ConfigTypeBooleanText"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{StaticResource CaptionTextBlockStyle}"
                Visibility="{Binding Entry.IsBoolean, ElementName=Root, Converter={StaticResource BoolToVis}}" />
            <TextBlock
                x:Uid="ConfigTypeIntegerText"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{StaticResource CaptionTextBlockStyle}"
                Visibility="{Binding Entry.IsInteger, ElementName=Root, Converter={StaticResource BoolToVis}}" />
            <TextBlock
                x:Uid="ConfigTypeChoiceText"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{StaticResource CaptionTextBlockStyle}"
                Visibility="{Binding Entry.IsChoice, ElementName=Root, Converter={StaticResource BoolToVis}}" />
            <TextBlock
                x:Uid="ConfigTypeTextText"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{StaticResource CaptionTextBlockStyle}"
                Visibility="{Binding Entry.IsText, ElementName=Root, Converter={StaticResource BoolToVis}}" />
        </Grid>

        <Grid
            Grid.Column="2"
            Width="220"
            HorizontalAlignment="Right"
            VerticalAlignment="Center">
            <ComboBox
                HorizontalAlignment="Stretch"
                ItemsSource="{Binding Entry.Choices, ElementName=Root}"
                SelectedItem="{Binding Entry.Value, ElementName=Root, Mode=TwoWay}"
                Visibility="{Binding Entry.HasChoices, ElementName=Root, Converter={StaticResource BoolToVis}}" />
            <TextBox
                HorizontalAlignment="Stretch"
                Text="{Binding Entry.Value, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Visibility="{Binding Entry.HasChoices, ElementName=Root, Converter={StaticResource BoolToVis}, ConverterParameter=True}" />
        </Grid>
    </Grid>
</UserControl>
