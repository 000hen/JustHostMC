<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="JustHostMC.App.Views.CreateShopServerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Uid="CreateShopServerDialog"
    DefaultButton="Primary"
    Style="{StaticResource DefaultContentDialogStyle}">

    <StackPanel Spacing="12">
        <TextBlock x:Uid="CreateShopServerDialogIntro" TextWrapping="Wrap" />
        <TextBlock
            Style="{StaticResource BodyStrongTextBlockStyle}"
            Text="{x:Bind ProjectName}"
            TextWrapping="Wrap" />
        <TextBox x:Name="NameBox" x:Uid="CreateShopServerNameBox" />
        <NumberBox
            x:Name="MemoryBox"
            x:Uid="CreateShopServerMemoryBox"
            LargeChange="1024"
            Maximum="65536"
            Minimum="512"
            SmallChange="512"
            SpinButtonPlacementMode="Inline"
            Value="4096" />
    </StackPanel>
</ContentDialog>
