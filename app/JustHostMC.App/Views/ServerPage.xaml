<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="JustHostMC.App.Views.ServerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:JustHostMC.App.Controls"
    xmlns:models="using:JustHostMC.App.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" SizeChanged="OnPageSizeChanged">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="Header" Grid.Row="0" Padding="24,18" RowSpacing="12" ColumnSpacing="16"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Row="0" Grid.Column="0" ColumnSpacing="12" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <controls:StatusDot Grid.Column="0" VerticalAlignment="Center" Status="{x:Bind Server.Status, Mode=OneWay}" />
                <StackPanel Grid.Column="1" Spacing="2">
                    <Button x:Uid="ServerTitleRenameButton"
                            Click="OnTitleRenameClick"
                            Padding="0"
                            BorderThickness="0"
                            Background="Transparent"
                            HorizontalAlignment="Left"
                            HorizontalContentAlignment="Left"
                            MaxWidth="560">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock x:Name="NameText"
                                       Text="{x:Bind Server.Name, Mode=OneWay}"
                                       Style="{StaticResource TitleTextBlockStyle}"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="1"
                                       MaxWidth="520"
                                       VerticalAlignment="Center" />
                            <FontIcon Glyph="&#xE70F;"
                                      FontSize="14"
                                      VerticalAlignment="Center"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Button>
                    <TextBlock Text="{x:Bind Server.StatusText, Mode=OneWay}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Grid>

            <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <controls:StatusDot VerticalAlignment="Center" Status="{x:Bind Server.Status, Mode=OneWay}" />
                    <TextBlock Text="{x:Bind Server.Name, Mode=OneWay}"
                               Style="{StaticResource TitleTextBlockStyle}" TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <StackPanel x:Name="MetaLine" Orientation="Horizontal" Spacing="8" Margin="20,0,0,0">
                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="{x:Bind Server.TypeText, Mode=OneWay}" />
                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="·"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="{x:Bind Server.McVersion, Mode=OneWay}" />
                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="·"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="{x:Bind PortText(Server.Port), Mode=OneWay}" />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button x:Name="StateButton" Click="OnStateButtonClick" MinWidth="128" Height="40"
                        Background="{x:Bind StateBrush(Server.Status), Mode=OneWay}"
                        Foreground="{x:Bind StateForeground(Server.Status), Mode=OneWay}"
                        IsEnabled="{x:Bind StateEnabled(Server.Status), Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="{x:Bind Server.StateActionGlyph, Mode=OneWay}" FontSize="16" />
                        <TextBlock Text="{x:Bind Server.StateActionText, Mode=OneWay}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button x:Uid="ServerMoreButton" Height="40">
                    <FontIcon Glyph="&#xE712;" FontSize="16" />
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuFlyoutItem x:Uid="ServerEditMenuItem" Click="OnEditClick">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE70F;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem x:Uid="ServerBackupsMenuItem" Click="OnBackupsClick">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE8F7;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem x:Uid="ServerOpenInstanceFolderMenuItem" Click="OnOpenInstanceFolderClick">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE8B7;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutSeparator />
                            <MenuFlyoutItem x:Uid="ServerDeleteMenuItem" Click="OnDeleteClick">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE74D;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
            </StackPanel>

            <Grid Grid.Row="1" Grid.ColumnSpan="2">
                <Border x:Name="MetaWide" Padding="0" CornerRadius="8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" Padding="12,9" RowSpacing="2"
                              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                              BorderThickness="0,0,1,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock x:Uid="ServerMetaTypeLabel" Grid.Row="0"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Row="1" Text="{x:Bind Server.TypeText, Mode=OneWay}"
                                       TextWrapping="WrapWholeWords" />
                        </Grid>

                        <Grid Grid.Column="1" Padding="12,9" RowSpacing="2"
                              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                              BorderThickness="0,0,1,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock x:Uid="ServerMetaVersionLabel" Grid.Row="0"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Row="1" Text="{x:Bind Server.McVersion, Mode=OneWay}"
                                       TextWrapping="WrapWholeWords" />
                        </Grid>

                        <Grid Grid.Column="2" Padding="12,9" RowSpacing="2"
                              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                              BorderThickness="0,0,1,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock x:Uid="ServerMetaPortLabel" Grid.Row="0"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Row="1" Text="{x:Bind PortValueText(Server.Port), Mode=OneWay}"
                                       TextWrapping="WrapWholeWords" />
                        </Grid>

                        <Grid Grid.Column="3" Padding="12,9" RowSpacing="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock x:Uid="ServerMetaMemoryLabel" Grid.Row="0"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Row="1" Text="{x:Bind MemoryText(Server.MemoryMb), Mode=OneWay}"
                                       TextWrapping="WrapWholeWords" />
                        </Grid>
                    </Grid>
                </Border>

                <Border x:Name="MetaMedium" Padding="0" CornerRadius="8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Row="0" Grid.Column="0" Padding="12,9" RowSpacing="2"
                              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                              BorderThickness="0,0,1,1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock x:Uid="ServerMetaTypeLabel" Grid.Row="0"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Row="1" Text="{x:Bind Server.TypeText, Mode=OneWay}"
                                       TextWrapping="WrapWholeWords" />
                        </Grid>

                        <Grid Grid.Row="0" Grid.Column="1" Padding="12,9" RowSpacing="2"
                              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                              BorderThickness="0,0,0,1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock x:Uid="ServerMetaVersionLabel" Grid.Row="0"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Row="1" Text="{x:Bind Server.McVersion, Mode=OneWay}"
                                       TextWrapping="WrapWholeWords" />
                        </Grid>

                        <Grid Grid.Row="1" Grid.Column="0" Padding="12,9" RowSpacing="2"
                              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                              BorderThickness="0,0,1,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock x:Uid="ServerMetaPortLabel" Grid.Row="0"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Row="1" Text="{x:Bind PortValueText(Server.Port), Mode=OneWay}"
                                       TextWrapping="WrapWholeWords" />
                        </Grid>

                        <Grid Grid.Row="1" Grid.Column="1" Padding="12,9" RowSpacing="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock x:Uid="ServerMetaMemoryLabel" Grid.Row="0"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Row="1" Text="{x:Bind MemoryText(Server.MemoryMb), Mode=OneWay}"
                                       TextWrapping="WrapWholeWords" />
                        </Grid>
                    </Grid>
                </Border>

                <Border x:Name="MetaNarrow" Padding="0" CornerRadius="8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Padding="12,9" RowSpacing="2"
                              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                              BorderThickness="0,0,0,1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock x:Uid="ServerMetaTypeLabel" Grid.Row="0"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Row="1" Text="{x:Bind Server.TypeText, Mode=OneWay}"
                                       TextWrapping="WrapWholeWords" />
                        </Grid>

                        <Grid Grid.Row="1" Padding="12,9" RowSpacing="2"
                              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                              BorderThickness="0,0,0,1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock x:Uid="ServerMetaVersionLabel" Grid.Row="0"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Row="1" Text="{x:Bind Server.McVersion, Mode=OneWay}"
                                       TextWrapping="WrapWholeWords" />
                        </Grid>

                        <Grid Grid.Row="2" Padding="12,9" RowSpacing="2"
                              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                              BorderThickness="0,0,0,1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock x:Uid="ServerMetaPortLabel" Grid.Row="0"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Row="1" Text="{x:Bind PortValueText(Server.Port), Mode=OneWay}"
                                       TextWrapping="WrapWholeWords" />
                        </Grid>

                        <Grid Grid.Row="3" Padding="12,9" RowSpacing="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock x:Uid="ServerMetaMemoryLabel" Grid.Row="0"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Row="1" Text="{x:Bind MemoryText(Server.MemoryMb), Mode=OneWay}"
                                       TextWrapping="WrapWholeWords" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Grid x:Name="DetailLayout" Grid.Row="1" Padding="24,12,24,24" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <SelectorBar x:Name="SectionBar" Grid.Row="0" SelectionChanged="OnSectionChanged">
                <SelectorBarItem x:Uid="ServerSectionConsole" Tag="console" IsSelected="True" />
                <SelectorBarItem x:Uid="ServerSectionPlayers" Tag="players" />
                <SelectorBarItem x:Uid="ServerSectionConfig" Tag="config" />
                <SelectorBarItem x:Uid="ServerSectionPerformance" Tag="performance" />
                <SelectorBarItem x:Uid="ServerSectionMods" Tag="mods" />
            </SelectorBar>

            <Grid Grid.Row="1">

                <!-- Console -->
                <Grid x:Name="ConsolePanel" RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0"
                            CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Padding="12" ColumnSpacing="8"
                                  BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                  BorderThickness="0,0,0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0"
                                          Glyph="&#xE756;"
                                          FontSize="16"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <Grid Grid.Column="1" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Uid="ConsoleOutputHeader"
                                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind Console.ServerName, Mode=OneWay}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </Grid>
                            </Grid>

                            <ScrollViewer x:Name="ConsoleLogScroller"
                                          Grid.Row="1"
                                          Background="{ThemeResource ControlFillColorDefaultBrush}"
                                          Padding="8">
                                <ItemsControl ItemsSource="{x:Bind Console.Lines}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       FontFamily="Consolas"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       IsTextSelectionEnabled="True" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                    <Grid Grid.Row="1" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Uid="ConsoleInput" x:Name="CommandBox" Grid.Column="0"
                                 Height="40"
                                 Text="{x:Bind Console.CommandText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 KeyDown="OnCommandKeyDown" />
                        <Button x:Uid="ConsoleSendCommandButton" Grid.Column="1"
                                MinWidth="104"
                                Height="40"
                                Command="{x:Bind Console.SendCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE724;" FontSize="14" />
                                <TextBlock x:Uid="ConsoleSendButtonLabel" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>

                <!-- Players -->
                <ScrollViewer x:Name="PlayersPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                    <Border Padding="16" CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <StackPanel Spacing="12">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0"
                                          Glyph="&#xE716;"
                                          FontSize="16"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}"
                                               Text="{x:Bind PlayersHeader(Players.Count), Mode=OneWay}" />
                                    <TextBlock x:Uid="PlayersEmptyHint"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               Visibility="{x:Bind HasNoPlayers(Players.Count), Mode=OneWay}" />
                                </StackPanel>
                                <Button Grid.Column="2"
                                        x:Uid="ManageBansButton"
                                        Click="OnManageBansClick"
                                        VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <SymbolIcon Symbol="BlockContact" />
                                        <TextBlock x:Uid="ManageBansButtonLabel" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <ListView ItemsSource="{x:Bind Players.Players, Mode=OneWay}"
                                      SelectionMode="None"
                                      Background="Transparent">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="models:PlayerItem">
                                        <Grid Padding="8" ColumnSpacing="10" MinHeight="48">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0"
                                                    Width="32"
                                                    Height="32"
                                                    CornerRadius="4"
                                                    Background="{ThemeResource ControlFillColorDefaultBrush}">
                                                <Image Source="{x:Bind HeadImage}"
                                                       Width="32"
                                                       Height="32"
                                                       Stretch="UniformToFill" />
                                            </Border>
                                            <TextBlock Grid.Column="1"
                                                       Text="{x:Bind Name}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                            <Button x:Uid="PlayerActionsButton"
                                                    Grid.Column="2"
                                                    Tag="{Binding}"
                                                    MinWidth="88"
                                                    Padding="10,6">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <FontIcon Glyph="&#xE712;" FontSize="14" />
                                                    <TextBlock x:Uid="PlayerActionsButtonLabel" />
                                                </StackPanel>
                                                <Button.Flyout>
                                                    <MenuFlyout>
                                                        <MenuFlyoutItem x:Uid="PlayerOpMenuItem" Tag="{Binding}" Click="OnPlayerOpClick">
                                                            <MenuFlyoutItem.Icon>
                                                                <SymbolIcon Symbol="Permissions" />
                                                            </MenuFlyoutItem.Icon>
                                                        </MenuFlyoutItem>
                                                        <MenuFlyoutItem x:Uid="PlayerDeopMenuItem" Tag="{Binding}" Click="OnPlayerDeopClick">
                                                            <MenuFlyoutItem.Icon>
                                                                <SymbolIcon Symbol="Permissions" />
                                                            </MenuFlyoutItem.Icon>
                                                        </MenuFlyoutItem>
                                                        <MenuFlyoutItem x:Uid="PlayerKickMenuItem" Tag="{Binding}" Click="OnPlayerKickClick">
                                                            <MenuFlyoutItem.Icon>
                                                                <SymbolIcon Symbol="Cancel" />
                                                            </MenuFlyoutItem.Icon>
                                                        </MenuFlyoutItem>
                                                        <MenuFlyoutItem x:Uid="PlayerBanMenuItem" Tag="{Binding}" Click="OnPlayerBanClick">
                                                            <MenuFlyoutItem.Icon>
                                                                <SymbolIcon Symbol="BlockContact" />
                                                            </MenuFlyoutItem.Icon>
                                                        </MenuFlyoutItem>
                                                        <MenuFlyoutSeparator />
                                                        <MenuFlyoutItem x:Uid="PlayerRawMenuItem" Tag="{Binding}" Click="OnPlayerRawClick">
                                                            <MenuFlyoutItem.Icon>
                                                                <SymbolIcon Symbol="View" />
                                                            </MenuFlyoutItem.Icon>
                                                        </MenuFlyoutItem>
                                                        <MenuFlyoutItem x:Uid="PlayerInventoryMenuItem" Tag="{Binding}" Click="OnPlayerInventoryClick">
                                                            <MenuFlyoutItem.Icon>
                                                                <SymbolIcon Symbol="List" />
                                                            </MenuFlyoutItem.Icon>
                                                        </MenuFlyoutItem>
                                                    </MenuFlyout>
                                                </Button.Flyout>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>
                </ScrollViewer>

                <!-- Configuration -->
                <Grid x:Name="ConfigPanel" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollMode="Disabled"
                                  HorizontalScrollBarVisibility="Disabled"
                                  HorizontalContentAlignment="Stretch">
                        <StackPanel Spacing="12" Padding="0,0,0,76" HorizontalAlignment="Stretch">
                            <TextBlock x:Uid="ConfigStoppedHint"
                                   TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Visibility="{x:Bind Config.CanModify, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />

                            <ProgressBar IsIndeterminate="True"
                                     Visibility="{x:Bind Config.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVis}}" />

                            <StackPanel Spacing="12"
                                    Visibility="{x:Bind Config.IsInitialLoading, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                <Expander IsExpanded="True"
                                      IsEnabled="False"
                                      HorizontalAlignment="Stretch"
                                      HorizontalContentAlignment="Stretch">
                                    <Expander.Header>
                                        <StackPanel Spacing="8">
                                            <Border Height="18" Width="180" HorizontalAlignment="Left" CornerRadius="4"
                                                Background="{ThemeResource ControlFillColorDefaultBrush}" />
                                            <Border Height="12" Width="360" HorizontalAlignment="Left" CornerRadius="4"
                                                Background="{ThemeResource ControlFillColorDefaultBrush}" />
                                        </StackPanel>
                                    </Expander.Header>
                                    <StackPanel Padding="0,4,0,0" Spacing="10">
                                        <Grid ColumnSpacing="16" MinHeight="64">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="88" />
                                                <ColumnDefinition Width="240" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Spacing="6" VerticalAlignment="Center">
                                                <Border Height="14" Width="180" HorizontalAlignment="Left" CornerRadius="4"
                                                    Background="{ThemeResource ControlFillColorDefaultBrush}" />
                                                <Border Height="11" Width="420" HorizontalAlignment="Left" CornerRadius="4"
                                                    Background="{ThemeResource ControlFillColorDefaultBrush}" />
                                                <Border Height="11" Width="140" HorizontalAlignment="Left" CornerRadius="4"
                                                    Background="{ThemeResource ControlFillColorDefaultBrush}" />
                                            </StackPanel>
                                            <Border Grid.Column="1" Height="14" Width="56" HorizontalAlignment="Left" VerticalAlignment="Center" CornerRadius="4"
                                                Background="{ThemeResource ControlFillColorDefaultBrush}" />
                                            <Border Grid.Column="2" Height="32" Width="220" HorizontalAlignment="Right" VerticalAlignment="Center" CornerRadius="4"
                                                Background="{ThemeResource ControlFillColorDefaultBrush}" />
                                        </Grid>
                                        <Grid ColumnSpacing="16" MinHeight="64">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="88" />
                                                <ColumnDefinition Width="240" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Spacing="6" VerticalAlignment="Center">
                                                <Border Height="14" Width="220" HorizontalAlignment="Left" CornerRadius="4"
                                                    Background="{ThemeResource ControlFillColorDefaultBrush}" />
                                                <Border Height="11" Width="500" HorizontalAlignment="Left" CornerRadius="4"
                                                    Background="{ThemeResource ControlFillColorDefaultBrush}" />
                                                <Border Height="11" Width="160" HorizontalAlignment="Left" CornerRadius="4"
                                                    Background="{ThemeResource ControlFillColorDefaultBrush}" />
                                            </StackPanel>
                                            <Border Grid.Column="1" Height="14" Width="52" HorizontalAlignment="Left" VerticalAlignment="Center" CornerRadius="4"
                                                Background="{ThemeResource ControlFillColorDefaultBrush}" />
                                            <Border Grid.Column="2" Height="32" Width="220" HorizontalAlignment="Right" VerticalAlignment="Center" CornerRadius="4"
                                                Background="{ThemeResource ControlFillColorDefaultBrush}" />
                                        </Grid>
                                    </StackPanel>
                                </Expander>

                                <Expander IsEnabled="False"
                                      HorizontalAlignment="Stretch"
                                      HorizontalContentAlignment="Stretch">
                                    <Expander.Header>
                                        <Border Height="18" Width="140" HorizontalAlignment="Left" CornerRadius="4"
                                            Background="{ThemeResource ControlFillColorDefaultBrush}" />
                                    </Expander.Header>
                                </Expander>
                            </StackPanel>

                            <controls:ConfigSectionExpander x:Uid="ConfigPropertiesSection"
                                                            IsExpanded="True"
                                                            ItemsSource="{x:Bind Config.Properties, Mode=OneWay}"
                                                            Visibility="{x:Bind Config.IsInitialLoading, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />

                            <controls:ConfigSectionExpander x:Uid="ConfigGameRulesSection"
                                                            ItemsSource="{x:Bind Config.GameRules, Mode=OneWay}"
                                                            Message="{x:Bind Config.GameRulesMessage, Mode=OneWay}"
                                                            HasMessage="{x:Bind Config.HasGameRulesMessage, Mode=OneWay}"
                                                            Visibility="{x:Bind Config.IsInitialLoading, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />

                            <TextBlock Text="{x:Bind Config.StatusMessage, Mode=OneWay}"
                                   TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </ScrollViewer>

                    <Border Margin="12"
                            Padding="14,10"
                            CornerRadius="8"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Bottom"
                            Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            Visibility="{x:Bind Config.HasModifiedConfiguration, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Uid="ConfigModifiedText"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Button Click="OnDiscardConfigChangesClick"
                                        IsEnabled="{x:Bind Config.CanDiscardChanges, Mode=OneWay}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <SymbolIcon Symbol="Undo" />
                                        <TextBlock x:Uid="ConfigDiscardButtonLabel" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource AccentButtonStyle}"
                                        Click="OnSaveModifiedConfigClick"
                                        IsEnabled="{x:Bind Config.CanSaveModifiedConfiguration, Mode=OneWay}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <SymbolIcon Symbol="Save" />
                                        <TextBlock x:Uid="ConfigSaveModifiedButtonLabel" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Performance -->
                <ScrollViewer x:Name="PerformancePanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                    <Grid ColumnSpacing="12" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Grid.Column="0" Padding="16" CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                            <StackPanel Spacing="8">
                                <TextBlock x:Uid="MetricsCpu" Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Text="{x:Bind Metrics.CpuText, Mode=OneWay}" Style="{StaticResource SubtitleTextBlockStyle}" />
                                <controls:Sparkline Height="56" Values="{x:Bind Metrics.CpuSeries, Mode=OneWay}"
                                                StrokeBrush="{ThemeResource AccentFillColorDefaultBrush}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="0" Grid.Column="1" Padding="16" CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                            <StackPanel Spacing="8">
                                <TextBlock x:Uid="MetricsMemory" Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Text="{x:Bind Metrics.MemText, Mode=OneWay}" Style="{StaticResource SubtitleTextBlockStyle}" />
                                <controls:Sparkline Height="56" Values="{x:Bind Metrics.MemSeries, Mode=OneWay}"
                                                StrokeBrush="{ThemeResource SystemFillColorSuccessBrush}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="0" Grid.Column="2" Padding="16" CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                            <StackPanel Spacing="8">
                                <TextBlock x:Uid="MetricsNetwork" Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Text="{x:Bind Metrics.NetText, Mode=OneWay}" Style="{StaticResource SubtitleTextBlockStyle}"
                                       Visibility="{x:Bind Metrics.NetworkAvailable, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                                <controls:Sparkline Height="56" Values="{x:Bind Metrics.NetSeries, Mode=OneWay}"
                                                StrokeBrush="{ThemeResource SystemFillColorCautionBrush}"
                                                Visibility="{x:Bind Metrics.NetworkAvailable, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                                <TextBlock x:Uid="MetricsNetworkUnavailable" TextWrapping="Wrap"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Visibility="{x:Bind Metrics.NetworkAvailable, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                            </StackPanel>
                        </Border>

                    </Grid>
                </ScrollViewer>

                <!-- Plugins / Mods -->
                <ScrollViewer x:Name="ModsPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="12">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind Mods.KindLabel, Mode=OneWay}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock x:Uid="ModsStoppedHint" Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Visibility="{x:Bind Mods.CanModify, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                            </StackPanel>
                            <Button x:Uid="ModsUploadButton" Grid.Column="1" Style="{StaticResource AccentButtonStyle}"
                                Click="OnUploadClick" IsEnabled="{x:Bind Mods.CanModify, Mode=OneWay}" />
                        </Grid>

                        <TextBlock x:Uid="ModsUnsupportedHint" TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Visibility="{x:Bind Mods.Supported, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />

                        <ProgressBar IsIndeterminate="True"
                                 Visibility="{x:Bind Mods.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVis}}" />

                        <ItemsControl ItemsSource="{x:Bind Mods.Files, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="8" ColumnSpacing="12"
                                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Grid.Column="0" Glyph="&#xE7B8;" FontSize="16" />
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2" Text="{Binding SizeText}" VerticalAlignment="Center"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <Button Grid.Column="3" x:Uid="ModsRemoveButton">
                                            <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                            <Button.Flyout>
                                                <Flyout>
                                                    <StackPanel Spacing="8" MaxWidth="240">
                                                        <TextBlock x:Uid="ModsRemoveConfirmText" TextWrapping="Wrap" />
                                                        <Button x:Uid="ModsRemoveConfirmButton" HorizontalAlignment="Right"
                                                            Click="OnRemoveModConfirm" Tag="{Binding}" />
                                                    </StackPanel>
                                                </Flyout>
                                            </Button.Flyout>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="{x:Bind Mods.StatusMessage, Mode=OneWay}" TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <StackPanel Grid.Row="2" Spacing="12">
                <Border Padding="16" CornerRadius="8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        Visibility="{x:Bind Server.ProgressTracker.IsActive, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <StackPanel Spacing="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{x:Bind Server.ProgressTracker.CurrentStep, Mode=OneWay}"
                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <Button Grid.Column="1" x:Uid="InstallDismissButton"
                                    Command="{x:Bind Server.ProgressTracker.DismissCommand}"
                                    Visibility="{x:Bind Server.ProgressTracker.HasFailed, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                        </Grid>
                        <ProgressBar IsIndeterminate="{x:Bind Server.ProgressTracker.IsIndeterminate, Mode=OneWay}"
                                     Value="{x:Bind Server.ProgressTracker.ProgressPercentage, Mode=OneWay}" />
                    </StackPanel>
                </Border>

                <InfoBar x:Uid="InstallReadyInfoBar"
                         IsOpen="{x:Bind Server.ProgressTracker.IsReadyToRun, Mode=OneWay}"
                         Severity="Success"
                         CloseButtonClick="OnReadyInfoBarClosed">
                    <InfoBar.ActionButton>
                        <Button x:Uid="InfoBarStartServerButton"
                                Click="OnStateButtonClick"
                                Style="{StaticResource AccentButtonStyle}" />
                    </InfoBar.ActionButton>
                </InfoBar>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
