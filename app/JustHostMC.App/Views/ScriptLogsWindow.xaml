<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="JustHostMC.App.Views.ScriptLogsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:JustHostMC.App.Models"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <Grid x:Name="Root"
          Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="LogsTitleBar">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="ms-appx:///Assets/StoreLogo.png" />
            </TitleBar.IconSource>
        </TitleBar>

        <Grid Grid.Row="1"
              Padding="16"
              ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">
            <Grid>
                <TextBlock x:Uid="ScriptLogsWindowEmpty"
                           Margin="24"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Visibility="{Binding LogSessions.Count, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />

                <ListView x:Name="LogList"
                          ItemsSource="{Binding LogSessions, Mode=OneWay}"
                          SelectionMode="Single"
                          Background="Transparent">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:ScriptLogSession">
                            <StackPanel Padding="6" Spacing="4">
                                <TextBlock Text="{x:Bind Title}"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           MaxLines="2" />
                                <TextBlock Text="{x:Bind StartedAtFormatted}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

            <Border Grid.Column="1"
                Padding="24"
                CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">
            <Grid>
                <TextBlock x:Uid="ScriptLogsWindowNoSelection"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Visibility="{Binding SelectedItem, ElementName=LogList, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding SelectedItem, ElementName=LogList, Converter={StaticResource BoolToVis}}">
                    <StackPanel Spacing="12"
                                DataContext="{Binding SelectedItem, ElementName=LogList}">
                        <TextBlock Text="{Binding Title}"
                                   Style="{StaticResource TitleTextBlockStyle}"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding StartedAtFormatted}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                        <Rectangle Height="1"
                                   Margin="0,4"
                                   Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                        <TextBlock x:Uid="ScriptLogsWindowDetailHeader"
                                   Margin="0,8,0,0"
                                   Style="{StaticResource SubtitleTextBlockStyle}" />
                        <ItemsControl ItemsSource="{Binding Entries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:ScriptLogEntry">
                                    <Border Padding="14"
                                            Margin="0,0,0,8"
                                            CornerRadius="6"
                                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                        <StackPanel Spacing="6">
                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{x:Bind ScriptName}"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{x:Bind TimestampFormatted}"
                                                           Style="{StaticResource CaptionTextBlockStyle}"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            </Grid>
                                            <TextBlock Text="{x:Bind ScriptId}"
                                                       FontFamily="Consolas"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       IsTextSelectionEnabled="True" />
                                            <TextBlock Text="{x:Bind Detail}"
                                                       FontFamily="Consolas"
                                                       FontSize="12"
                                                       IsTextSelectionEnabled="True"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
