<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="JustHostMC.App.Controls.ScriptEntryCard"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    HorizontalAlignment="Stretch"
    HorizontalContentAlignment="Stretch">

    <Border Padding="14"
            Margin="0,0,0,8"
            CornerRadius="8"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1">
        <Grid ColumnSpacing="12" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{Binding Item.Name, ElementName=Root}"
                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <Border x:Uid="ScriptsBuiltinBadge"
                            Padding="6,1"
                            CornerRadius="4"
                            VerticalAlignment="Center"
                            Background="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                            Visibility="{Binding Item.IsBuiltIn, ElementName=Root, Converter={StaticResource BoolToVis}}">
                        <TextBlock x:Uid="ScriptsBuiltinBadgeLabel"
                                   Style="{StaticResource CaptionTextBlockStyle}" />
                    </Border>
                </StackPanel>
                <TextBlock Text="{Binding Item.Description, ElementName=Root}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="WrapWholeWords" />
                <TextBlock Text="{Binding Item.GrantedSummary, ElementName=Root}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           TextWrapping="WrapWholeWords" />
            </StackPanel>

            <ToggleSwitch x:Name="EnabledToggle"
                          x:Uid="ScriptsEnabledToggle"
                          Grid.Column="1"
                          VerticalAlignment="Center"
                          IsOn="{Binding Item.Enabled, ElementName=Root, Mode=OneWay}"
                          Visibility="{Binding Item.SupportsToggle, ElementName=Root, Converter={StaticResource BoolToVis}}"
                          Toggled="OnEnabledToggled" />

            <Button x:Uid="ScriptsRemoveButton"
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    IsEnabled="{Binding Item.CanRemove, ElementName=Root}"
                    Click="OnRemoveClick">
                <FontIcon Glyph="&#xE74D;" FontSize="14" />
            </Button>

            <Expander Grid.Row="1"
                      Grid.ColumnSpan="3"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch"
                      Visibility="{Binding Item.SupportsLogs, ElementName=Root, Converter={StaticResource BoolToVis}}">
                <Expander.Header>
                    <TextBlock x:Uid="ScriptsScriptLogsHeader"
                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                </Expander.Header>
                <Border MinHeight="72"
                        MaxHeight="180"
                        CornerRadius="6"
                        Background="{ThemeResource ControlFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <Grid>
                        <TextBlock x:Uid="ScriptsScriptLogsEmpty"
                                   Margin="12"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Visibility="{Binding Item.LogLines.Count, ElementName=Root, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Item.LogLines, ElementName=Root}"
                                          Padding="10">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <TextBlock Text="{x:Bind}"
                                                   FontFamily="Consolas"
                                                   FontSize="12"
                                                   IsTextSelectionEnabled="True"
                                                   TextWrapping="Wrap" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Expander>
        </Grid>
    </Border>
</UserControl>
