<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="JustHostMC.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:JustHostMC.App.Controls"
    xmlns:models="using:JustHostMC.App.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="Base"/>
    </Window.SystemBackdrop>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="SimpleTitleBar"
            Title="JustHostMC"
            IsBackButtonVisible="{x:Bind ContentFrame.CanGoBack, Mode=OneWay}"
            IsBackButtonEnabled="{x:Bind ContentFrame.CanGoBack, Mode=OneWay}"
            BackRequested="OnTitleBarBackRequested"
            IsPaneToggleButtonVisible="True"
            PaneToggleRequested="OnTitleBarPaneToggleRequested">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="ms-appx:///Assets/StoreLogo.png"/>
            </TitleBar.IconSource>
        </TitleBar>
        
        <NavigationView x:Name="Nav"
                    PaneDisplayMode="Left"
                    IsBackButtonVisible="Collapsed"
                    IsPaneToggleButtonVisible="False"
                    IsSettingsVisible="False"
                    IsTitleBarAutoPaddingEnabled="False"
                    MenuItemsSource="{x:Bind Shell.Main.NavigationItems}"
                    FooterMenuItemsSource="{x:Bind Shell.Main.FooterNavigationItems}"
                    SelectionChanged="OnNavSelectionChanged"
                    ItemInvoked="OnNavItemInvoked"
                    Grid.Row="1">
            <NavigationView.Resources>
                <DataTemplate x:Key="HomeNavigationItemTemplate">
                    <NavigationViewItem x:Uid="NavHome" Tag="home">
                        <NavigationViewItem.Icon>
                            <FontIcon Glyph="&#xE80F;" />
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>
                </DataTemplate>

                <DataTemplate x:Key="ServerNavigationItemTemplate" x:DataType="models:ServerItem">
                    <NavigationViewItem
                        ToolTipService.ToolTip="{x:Bind ProgressTracker.TooltipText, Mode=OneWay}"
                        AutomationProperties.Name="{x:Bind NavigationAutomationName, Mode=OneWay}">
                        <NavigationViewItem.Icon>
                            <FontIcon Glyph="&#x2B24;"
                                      FontFamily="Segoe UI Symbol"
                                      FontSize="24"
                                      Foreground="{x:Bind NavigationStatusBrush, Mode=OneWay}"
                                      controls:StatusDotBehavior.Status="{x:Bind Status, Mode=OneWay}" />
                        </NavigationViewItem.Icon>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{x:Bind Name, Mode=OneWay}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                            <InfoBadge Grid.Column="1"
                                       VerticalAlignment="Center"
                                       Visibility="{x:Bind NavigationInfoBadgeVisibility, Mode=OneWay}" />
                        </Grid>
                    </NavigationViewItem>
                </DataTemplate>

                <DataTemplate x:Key="AddServerNavigationItemTemplate">
                    <NavigationViewItem x:Uid="NavAddServer" Tag="add" SelectsOnInvoked="False">
                        <NavigationViewItem.Icon>
                            <FontIcon Glyph="&#xE710;" />
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>
                </DataTemplate>

                <DataTemplate x:Key="ScriptsNavigationItemTemplate">
                    <NavigationViewItem x:Uid="NavScripts" Tag="scripts">
                        <NavigationViewItem.Icon>
                            <FontIcon Glyph="&#xE756;" />
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>
                </DataTemplate>

                <DataTemplate x:Key="SettingsNavigationItemTemplate">
                    <NavigationViewItem x:Uid="NavSettings" Tag="settings">
                        <NavigationViewItem.Icon>
                            <FontIcon Glyph="&#xE713;" />
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>
                </DataTemplate>

            </NavigationView.Resources>

            <NavigationView.MenuItemTemplateSelector>
                <controls:NavigationMenuItemTemplateSelector
                    HomeTemplate="{StaticResource HomeNavigationItemTemplate}"
                    ServerTemplate="{StaticResource ServerNavigationItemTemplate}"
                    AddServerTemplate="{StaticResource AddServerNavigationItemTemplate}"
                    ScriptsTemplate="{StaticResource ScriptsNavigationItemTemplate}"
                    SettingsTemplate="{StaticResource SettingsNavigationItemTemplate}" />
            </NavigationView.MenuItemTemplateSelector>

            <NavigationView.PaneFooter>
                <Grid x:Name="PaneFooterGrid"
                      Visibility="{Binding HasActiveTracker, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                      MinHeight="48" Padding="12,8">
                    <StackPanel Spacing="6" VerticalAlignment="Center"
                                Visibility="{Binding ElementName=Nav, Path=IsPaneOpen, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <Grid ColumnSpacing="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding CurrentActiveTracker.ServerName, Mode=OneWay}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="{Binding ActiveIndexText, Mode=OneWay}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding HasMultipleActive, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                            <Button Grid.Column="2" Padding="4,2" MinWidth="24" MinHeight="24"
                                    Command="{Binding PreviousCommand}"
                                    Visibility="{Binding HasMultipleActive, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                <FontIcon Glyph="&#xE76B;" FontSize="10" />
                            </Button>
                            <Button Grid.Column="3" Padding="4,2" MinWidth="24" MinHeight="24"
                                    Command="{Binding NextCommand}"
                                    Visibility="{Binding HasMultipleActive, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                <FontIcon Glyph="&#xE76C;" FontSize="10" />
                            </Button>
                        </Grid>
                        <ProgressBar IsIndeterminate="{Binding CurrentActiveTracker.IsIndeterminate, Mode=OneWay}"
                                     Value="{Binding CurrentActiveTracker.ProgressPercentage, Mode=OneWay}"
                                     HorizontalAlignment="Stretch" />
                        <TextBlock Text="{Binding CurrentActiveTracker.CurrentStep, Mode=OneWay}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <Grid VerticalAlignment="Center" HorizontalAlignment="Center"
                          Visibility="{Binding ElementName=Nav, Path=IsPaneOpen, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter='invert'}">
                        <ProgressRing Width="20" Height="20"
                                      IsIndeterminate="{Binding CurrentActiveTracker.IsIndeterminate, Mode=OneWay}"
                                      Value="{Binding CurrentActiveTracker.ProgressPercentage, Mode=OneWay}"
                                      ToolTipService.ToolTip="{Binding CurrentActiveTracker.CurrentStep, Mode=OneWay}" />
                    </Grid>
                </Grid>
            </NavigationView.PaneFooter>

            <Frame x:Name="ContentFrame" Navigated="OnContentFrameNavigated" />
        </NavigationView>

        <TeachingTip x:Name="ServerStateTip"
                     Grid.RowSpan="2"
                     PreferredPlacement="Right"
                     IsLightDismissEnabled="True" />
    </Grid>
</Window>
