<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="JustHostMC.App.Views.ShopDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:JustHostMC.App.Models"
    xmlns:grpc="using:McManager.Grpc"
    xmlns:local="using:JustHostMC.App.Views"
    mc:Ignorable="d">

    <Grid Padding="16,8,16,0" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Hero -->
        <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid Width="64" Height="64" VerticalAlignment="Top">
                <FontIcon Glyph="&#xE7B8;" FontSize="26"
                          Visibility="{x:Bind ViewModel.Card.FallbackIconVisibility, Mode=OneWay}" />
                <Border CornerRadius="8" Visibility="{x:Bind ViewModel.Card.IconVisibility, Mode=OneWay}">
                    <Image Source="{x:Bind ViewModel.Card.Icon, Mode=OneWay}" Stretch="UniformToFill" />
                </Border>
            </Grid>
            <StackPanel Grid.Column="1" Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="{x:Bind ViewModel.Card.Title, Mode=OneWay}"
                               Style="{StaticResource TitleTextBlockStyle}"
                               TextTrimming="CharacterEllipsis" />
                    <Border VerticalAlignment="Center"
                            Padding="8,2"
                            CornerRadius="10"
                            Background="{ThemeResource ControlFillColorSecondaryBrush}">
                        <TextBlock Text="{x:Bind ViewModel.SourceName}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </Border>
                </StackPanel>
                <TextBlock Text="{x:Bind ViewModel.Card.Summary, Mode=OneWay}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"
                           MaxLines="2"
                           TextTrimming="CharacterEllipsis" />
                <StackPanel Orientation="Horizontal" Spacing="14">
                    <TextBlock Text="{x:Bind ViewModel.Card.Author, Mode=OneWay}"
                               Visibility="{x:Bind ViewModel.Card.AuthorVisibility, Mode=OneWay}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE896;" FontSize="11"
                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.Card.DownloadsText, Mode=OneWay}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
            <HyperlinkButton x:Uid="ShopOpenWebsite"
                             Grid.Column="2"
                             VerticalAlignment="Top"
                             Click="OnOpenWebsite"
                             Visibility="{x:Bind HasUrl(ViewModel.WebsiteUrl), Mode=OneWay}" />
        </Grid>

        <!-- Overview / Versions switch -->
        <SelectorBar x:Name="TabBar" Grid.Row="1" SelectionChanged="OnTabChanged">
            <SelectorBarItem x:Name="OverviewTab" x:Uid="ShopOverviewTab" IsSelected="True" />
            <SelectorBarItem x:Name="VersionsTab" x:Uid="ShopVersionsTab" />
        </SelectorBar>

        <!-- Overview -->
        <Grid Grid.Row="2" x:Name="OverviewPanel" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <FlipView Height="260"
                      CornerRadius="8"
                      ItemsSource="{x:Bind ViewModel.Gallery, Mode=OneWay}"
                      Visibility="{x:Bind BoolToVisibility(ViewModel.HasGallery), Mode=OneWay}">
                <FlipView.ItemTemplate>
                    <DataTemplate x:DataType="models:ShopGalleryItem">
                        <Grid>
                            <Image Source="{x:Bind Image}" Stretch="Uniform" />
                            <Border VerticalAlignment="Bottom"
                                    Padding="12,6"
                                    Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                                    Visibility="{x:Bind TitleVisibility}">
                                <TextBlock Text="{x:Bind Title}"
                                           Style="{StaticResource CaptionTextBlockStyle}" />
                            </Border>
                        </Grid>
                    </DataTemplate>
                </FlipView.ItemTemplate>
            </FlipView>

            <Grid Grid.Row="1">
                <ProgressRing Width="40" Height="40"
                              IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
                <WebView2 x:Name="BodyView"
                          Visibility="{x:Bind InvertBoolToVisibility(ViewModel.IsLoading), Mode=OneWay}" />
            </Grid>
        </Grid>

        <!-- Versions -->
        <Grid Grid.Row="2" x:Name="VersionsPanel" Visibility="Collapsed">
            <ListView ItemsSource="{x:Bind ViewModel.Versions, Mode=OneWay}"
                      SelectionMode="None">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:ShopVersionItem">
                        <Grid ColumnSpacing="12"
                              Padding="0,8"
                              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                              BorderThickness="0,0,0,1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border VerticalAlignment="Center"
                                    Padding="8,2"
                                    CornerRadius="10"
                                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                    Visibility="{x:Bind ChannelVisibility}">
                                <TextBlock Text="{x:Bind ChannelText}"
                                           Style="{StaticResource CaptionTextBlockStyle}" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{x:Bind Name}"
                                               Style="{StaticResource BodyStrongTextBlockStyle}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{x:Bind VersionNumber}"
                                               VerticalAlignment="Bottom"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="{x:Bind GameVersionsText}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="{x:Bind InfoLine}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                            <Button x:Uid="ShopInstallButton"
                                    Grid.Column="2"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Click="OnInstallClick"
                                    Tag="{x:Bind}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <ProgressRing Width="40" Height="40"
                          IsActive="{x:Bind ViewModel.IsVersionsLoading, Mode=OneWay}" />
            <TextBlock x:Uid="ShopNoVersions"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Visibility="{x:Bind ShowNoVersions(ViewModel.IsVersionsLoading, ViewModel.Versions.Count), Mode=OneWay}" />
        </Grid>

        <!-- Install progress / status -->
        <StackPanel Grid.Row="3" Spacing="8" Margin="0,0,0,12">
            <ProgressBar Value="{x:Bind ProgressPercent(ViewModel.InstallProgress), Mode=OneWay}"
                         Maximum="100"
                         Visibility="{x:Bind BoolToVisibility(ViewModel.IsInstalling), Mode=OneWay}" />
            <InfoBar IsOpen="{x:Bind HasStatus(ViewModel.StatusMessage), Mode=OneWay}"
                     IsClosable="False"
                     Severity="{x:Bind StatusSeverity(ViewModel.InstallSucceeded), Mode=OneWay}"
                     Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" />
        </StackPanel>
    </Grid>
</Page>
