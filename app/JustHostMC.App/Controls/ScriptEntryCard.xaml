<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="JustHostMC.App.Controls.ScriptEntryCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="Root"
    HorizontalAlignment="Stretch"
    HorizontalContentAlignment="Stretch"
    mc:Ignorable="d">

    <Border
        Margin="0,0,0,8"
        Padding="14"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="8">
        <Grid ColumnSpacing="12" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="{Binding Item.Name, ElementName=Root}" />
                    <Border
                        x:Uid="ScriptsBuiltinBadge"
                        Padding="6,1"
                        VerticalAlignment="Center"
                        Background="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                        CornerRadius="4"
                        Visibility="{Binding Item.IsBuiltIn, ElementName=Root, Converter={StaticResource BoolToVis}}">
                        <TextBlock x:Uid="ScriptsBuiltinBadgeLabel" Style="{StaticResource CaptionTextBlockStyle}" />
                    </Border>
                </StackPanel>
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="{Binding Item.Description, ElementName=Root}"
                    TextWrapping="WrapWholeWords" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="{Binding Item.GrantedSummary, ElementName=Root}"
                    TextWrapping="WrapWholeWords" />
            </StackPanel>

            <ToggleSwitch
                x:Name="EnabledToggle"
                x:Uid="ScriptsEnabledToggle"
                Grid.Column="1"
                VerticalAlignment="Center"
                IsOn="{Binding Item.Enabled, ElementName=Root, Mode=OneWay}"
                Toggled="OnEnabledToggled"
                Visibility="{Binding Item.SupportsToggle, ElementName=Root, Converter={StaticResource BoolToVis}}" />

            <Button
                x:Uid="ScriptsRemoveButton"
                Grid.Column="2"
                VerticalAlignment="Center"
                Click="OnRemoveClick"
                IsEnabled="{Binding Item.CanRemove, ElementName=Root}">
                <FontIcon FontSize="14" Glyph="&#xE74D;" />
            </Button>

            <Expander
                Grid.Row="1"
                Grid.ColumnSpan="3"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                Visibility="{Binding Item.SupportsLogs, ElementName=Root, Converter={StaticResource BoolToVis}}">
                <Expander.Header>
                    <TextBlock x:Uid="ScriptsScriptLogsHeader" Style="{StaticResource BodyStrongTextBlockStyle}" />
                </Expander.Header>
                <Border
                    MinHeight="72"
                    MaxHeight="180"
                    Background="{ThemeResource ControlFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                    <Grid>
                        <TextBlock
                            x:Uid="ScriptsScriptLogsEmpty"
                            Margin="12"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Visibility="{Binding Item.LogLines.Count, ElementName=Root, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl Padding="10" ItemsSource="{Binding Item.LogLines, ElementName=Root}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <TextBlock
                                            FontFamily="Consolas"
                                            FontSize="12"
                                            IsTextSelectionEnabled="True"
                                            Text="{x:Bind}"
                                            TextWrapping="Wrap" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Expander>
        </Grid>
    </Border>
</UserControl>
